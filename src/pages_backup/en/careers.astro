---
import BaseLayout from "@layouts/BaseLayout.astro";
import Recruitment from "@components/en/Recruitment.astro";
import WaveHighlightTitle from "@components/WaveHighlightTitle.astro";

const pageTitle = "Careers | ZetaX - Deep Tech Startup from UTokyo";
const pageDescription = "Change the world with Photonics Reservoir Computing and AI. ZetaX is hiring engineers and researchers to challenge technological innovation.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="container mx-auto px-4 py-20">
    <section class="mb-16">
      <div class="max-w-4xl mx-auto">
        <div class="bg-gradient-to-br from-slate-50 to-blue-50 dark:from-slate-900/50 dark:to-blue-900/20 rounded-3xl p-8 md:p-12 border border-slate-200 dark:border-slate-700 shadow-sm">
          <div class="space-y-6">
            <p class="text-2xl md:text-3xl text-slate-800 dark:text-slate-100 leading-relaxed">
              At <span class="font-bold text-slate-900 dark:text-white">ZetaX</span>,
              we are looking for passionate and talented team members to challenge the cutting-edge technologies of <span class="font-semibold text-blue-600 dark:text-blue-400">Photonics</span> and <span class="font-semibold text-blue-600 dark:text-blue-400">AI</span>.
            </p>
            <div class="pt-4 border-t border-slate-300 dark:border-slate-600">
              <p class="text-xl md:text-2xl font-semibold text-slate-700 dark:text-slate-200">
                Let's create the next Unicorn from Japan.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Recruitment />
  </div>
</BaseLayout>
