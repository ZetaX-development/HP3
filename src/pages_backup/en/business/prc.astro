---
import BaseLayout from "@layouts/BaseLayout.astro";
import PRCTechnology from "@components/en/PRCTechnology.astro";

const pageTitle = "PRC | ZetaX";
const pageDescription = "About PRC, the next-generation optical computing technology.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="relative overflow-hidden h-[60vh] flex items-center justify-center bg-slate-900">
    <!-- Background Effects -->
    <div class="absolute inset-0 bg-slate-900 z-0">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-violet-900/30 via-slate-900 to-slate-900"></div>
    </div>
    
    <div class="container mx-auto px-4 relative z-10 text-center flex flex-col justify-center h-full">
      <h1 class="text-6xl md:text-8xl font-bold mb-12 text-transparent bg-clip-text bg-gradient-to-r from-violet-400 via-fuchsia-300 to-purple-200 drop-shadow-2xl tracking-tight md:translate-x-[-20px] md:translate-y-[20px]">
        PRC
      </h1>
      <p class="text-2xl md:text-3xl text-slate-300 max-w-5xl mx-auto font-light leading-relaxed tracking-wide">
        Next-Generation Ultra-High-Speed, Low-Power Computing <br />Leveraging Optical Physics
      </p>
    </div>
  </div>
  <div class="py-16 bg-slate-950">
     <!-- Reusing the PRCTechnology component -->
    <PRCTechnology />
  </div>
</BaseLayout>
