---
import BaseLayout from "@layouts/BaseLayout.astro";

import TeamGrid from "@components/Team/TeamGrid.astro";
import CompanyDescription from "@components/Team/CompanyDescription.astro";
import TeamMemberCard from "@components/Team/TeamMemberCard.astro";
import teamData from "@config/ja/teamData.json.ts";

// Split team into CEOs and Engineers
const ceos = teamData.slice(0, 2);
const engineers = teamData.slice(2);

// Split engineers into rows of 3 for staggered animation
const engineersRow1 = engineers.slice(0, 3);
const engineersRow2 = engineers.slice(3, 6);

const pageTitle = "メンバー紹介 | ZetaX - 東大発DeepTechスタートアップ";
const pageDescription = "ZetaXを率いる多彩なメンバーを紹介します。AI、物理、フォトニクスの専門家が集結した東大発DeepTechスタートアップチーム。";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="relative overflow-hidden h-[60vh] flex items-center justify-center bg-slate-900">
    <!-- Background Gradient/Effects -->
    <div class="absolute inset-0 bg-slate-900 z-0">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-violet-900/30 via-slate-900 to-slate-900"></div>
      <div class="absolute bottom-0 left-0 w-full h-1/2 bg-gradient-to-t from-slate-900 to-transparent"></div>
    </div>
    
    <!-- Animated background elements -->
    <div class="absolute inset-0 z-0 opacity-20">
        <div class="absolute top-[30%] left-[20%] w-64 h-64 bg-fuchsia-600 rounded-full blur-[100px] animate-pulse"></div>
        <div class="absolute bottom-[20%] right-[20%] w-80 h-80 bg-blue-600 rounded-full blur-[100px] animate-pulse" style="animation-delay: 1.5s;"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10 text-center">
      <h1 class="text-6xl md:text-8xl font-bold mb-0 tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-yellow-300 via-amber-400 to-orange-300 drop-shadow-2xl">
        Our Members
      </h1>
    </div>
  </div>
  

  
  
  <!-- CEO Section -->
  <TeamGrid 
    members={ceos}
    title="Leadership"
    size="large"
    columns={2}
    dataAos="fade-up"
    underlineColor="from-blue-500 to-teal-400"
  />
  
  <!-- Engineers Section with row-by-row slide-up animation -->
  <section class="engineers-section overflow-visible">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-white tracking-tight" data-mos="fade-down">
          Engineering Team
        </h2>
        <div class="h-1 w-24 bg-gradient-to-r from-purple-500 to-pink-500 mx-auto rounded-full"></div>
      </div>
      
      <!-- Row 1 -->
      <div class="engineer-row" data-mos="slide-up" data-mos-offset="100" data-mos-delay="0">
        <div class="team-grid">
          {engineersRow1.map((member) => (
            <TeamMemberCard
              member={member}
              size="normal"
              dataAos="fade-up"
            />
          ))}
        </div>
      </div>
      
      <!-- Row 2 -->
      <div class="engineer-row" data-mos="slide-up" data-mos-offset="100" data-mos-delay="200">
        <div class="team-grid">
          {engineersRow2.map((member) => (
            <TeamMemberCard
              member={member}
              size="normal"
              dataAos="fade-up"
            />
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Additional page-specific styles */
  :global(body) {
    background: linear-gradient(
      180deg,
      rgba(15, 23, 42, 1) 0%,
      rgba(30, 41, 59, 1) 50%,
      rgba(15, 23, 42, 1) 100%
    );
  }

  .engineers-section {
    padding: 4rem 0;
  }



  .engineer-row {
    margin-bottom: 2rem;
  }

  .team-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .team-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .engineers-section {
      padding: 3rem 0;
    }



    .engineer-row {
      margin-bottom: 1.5rem;
    }

    .team-grid {
      gap: 1.5rem;
    }
  }
</style>
