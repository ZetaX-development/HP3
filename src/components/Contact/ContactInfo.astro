---
import WaveHighlightTitle from "@components/WaveHighlightTitle.astro";
---

<section class="mv-section">
  <div class="container mx-auto px-4">
    
    <div class="mv-container">
      <!-- Mission Circle -->
      <div class="mv-circle mission-circle" data-mos="fade-right">
        <div class="circle-content">
          <h3 class="circle-title">Mission</h3>
          <p class="circle-main-text">最新技術を実装し<br/>社会を豊かに</p>
          <p class="circle-desc">最先端の研究成果を社会実装し、<br/>産業課題の解決に取り組みます</p>
        </div>
      </div>

      <!-- Center Interaction (Arrows) -->
      <div class="mv-interaction">
        <svg class="interaction-arrows" viewBox="0 0 200 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Top Arrow (Left to Right) -->
          <path d="M20 50 Q 100 10 180 50" stroke="url(#grad1)" stroke-width="2" marker-end="url(#arrowhead)"/>
          <!-- Bottom Arrow (Right to Left) -->
          <path d="M180 50 Q 100 90 20 50" stroke="url(#grad2)" stroke-width="2" marker-end="url(#arrowhead)"/>
          
          <defs>
            <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:1" />
              <stop offset="100%" style="stop-color:#8b5cf6;stop-opacity:1" />
            </linearGradient>
            <linearGradient id="grad2" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" style="stop-color:#8b5cf6;stop-opacity:1" />
              <stop offset="100%" style="stop-color:#3b82f6;stop-opacity:1" />
            </linearGradient>
            <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
              <polygon points="0 0, 10 3.5, 0 7" fill="#6366f1" />
            </marker>
          </defs>
        </svg>
      </div>

      <!-- Vision Circle -->
      <div class="mv-circle vision-circle" data-mos="fade-left">
        <div class="circle-content">
          <h3 class="circle-title">Vision</h3>
          <p class="circle-main-text">日本発ユニコーンの<br/>創出</p>
          <p class="circle-desc">フォトニクスとAIの融合により、<br/>グローバルなインパクトを実現します</p>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .mv-section {
    padding: 6rem 0;
    overflow: hidden;
    background: var(--section-bg, #f8fafc);
  }

  :global(.dark) .mv-section {
    --section-bg: #0f172a;
  }

  .mv-container {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    gap: 2rem;
  }

  /* Circles */
  .mv-circle {
    width: 450px;
    height: 450px;
    border-radius: 50%;
    border: 1px solid var(--circle-border, rgba(59, 130, 246, 0.3));
    background: var(--circle-bg, rgba(255, 255, 255, 0.5));
    backdrop-filter: blur(10px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 3rem;
    position: relative;
    z-index: 10;
    transition: all 0.5s ease;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
  }

  :global(.dark) .mv-circle {
    --circle-border: rgba(99, 102, 241, 0.3);
    --circle-bg: rgba(30, 41, 59, 0.5);
  }

  .mv-circle:hover {
    transform: scale(1.02);
    border-color: var(--highlight-color, #3b82f6);
    box-shadow: 0 20px 40px rgba(59, 130, 246, 0.15);
  }

  /* Specific border gradients or details */
  .mission-circle {
    /* Slightly left positioning adjustment if needed */
  }

  .vision-circle {
    /* Slightly right positioning adjustment if needed */
  }

  .circle-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .circle-title {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--title-color, #64748b);
    position: relative;
  }

  .circle-title::after {
    content: '';
    display: block;
    width: 40px;
    height: 2px;
    background: currentColor;
    margin: 0.5rem auto 0;
  }

  .circle-main-text {
    font-size: 1.75rem;
    font-weight: 800;
    line-height: 1.3;
    color: var(--main-text-color, #0f172a);
    background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  :global(.dark) .circle-main-text {
    --main-text-color: #f1f5f9;
    /* keep gradient on dark mode */
  }

  .circle-desc {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--desc-color, #475569);
    max-width: 300px;
  }

  :global(.dark) .circle-desc {
    --desc-color: #94a3b8;
  }

  /* Interaction (Arrows) */
  .mv-interaction {
    position: absolute;
    width: 200px;
    height: 100px;
    z-index: 5;
    pointer-events: none;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .interaction-arrows {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .mv-circle {
      width: 380px;
      height: 380px;
      padding: 2rem;
    }
  }

  @media (max-width: 768px) {
    .mv-container {
      flex-direction: column;
      gap: 3rem;
    }

    .mv-circle {
      width: 320px;
      height: 320px;
    }

    .mv-interaction {
      transform: translate(-50%, -50%) rotate(90deg);
      width: 150px;
    }
  }
</style>
