---
---

  <div class="story-section">
    <div class="image-container-full mb-12">
      <img src="/other/image15.png" alt="プロジェクトの流れ" class="w-full h-auto rounded-xl shadow-lg" />
    </div>
  </div>

<style>
  .tech-block {
    margin-bottom: 4rem;
    padding: 2.5rem;
    background: var(--block-bg, #ffffff);
    border-radius: 1.5rem;
    box-shadow: 0 4px 20px var(--block-shadow, rgba(0, 0, 0, 0.06));
  }

  :global(.dark) .tech-block {
    --block-bg: rgba(30, 41, 59, 0.6);
    --block-shadow: rgba(0, 0, 0, 0.3);
  }

  .block-title {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 2rem;
    color: var(--title-color, #0f172a);
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  :global(.dark) .block-title {
    --title-color: #f1f5f9;
  }

  .story-step {
    padding: 1.5rem;
    background: var(--step-bg, #f8fafc);
    border-radius: 1rem;
    border-left: 4px solid #667eea;
  }

  :global(.dark) .story-step {
    --step-bg: rgba(15, 23, 42, 0.6);
  }

  .story-step h4 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--step-title, #1e293b);
  }

  :global(.dark) .story-step h4 {
    --step-title: #f1f5f9;
  }

  .story-step p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--step-text, #64748b);
  }

  :global(.dark) .story-step p {
    --step-text: #94a3b8;
  }
</style>
