---
---

  <div class="flow-container">
    <!-- Step 1 -->
    <div class="flow-step">
      <div class="step-icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 20.25c4.97 0 9-3.694 9-8.25s-4.03-8.25-9-8.25S3 7.444 3 12c0 2.104.859 4.023 2.273 5.48.432.447.74 1.04.586 1.641a4.483 4.483 0 0 1-.923 1.785A5.969 5.969 0 0 0 6 21c1.282 0 2.47-.402 3.445-1.087.81.22 1.668.337 2.555.337Z" />
        </svg>
      </div>
      <div class="step-content">
  <span class="step-number">01</span>
  <h4 class="step-title">Discovery & Consulting</h4>
  <p class="step-desc">Clarify challenges and define AI adoption goals.</p>
</div>
      <div class="step-arrow"></div>
    </div>

    <!-- Step 2 -->
    <div class="flow-step">
      <div class="step-icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23-.693L5 14.5" />
        </svg>
      </div>
      <div class="step-content">
        <span class="step-number">02</span>
        <h4 class="step-title">PoC & Verification</h4>
        <p class="step-desc">Validate feasibility using real-world data.</p>
      </div>
      <div class="step-arrow"></div>
    </div>

    <!-- Step 3 -->
    <div class="flow-step">
      <div class="step-icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
        </svg>
      </div>
      <div class="step-content">
        <span class="step-number">03</span>
        <h4 class="step-title">Development</h4>
        <p class="step-desc">Develop production-ready AI models and core systems.</p>
      </div>
      <div class="step-arrow"></div>
    </div>

    <!-- Step 4 -->
    <div class="flow-step">
      <div class="step-icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
        </svg>
      </div>
      <div class="step-content">
        <span class="step-number">04</span>
        <h4 class="step-title">Deployment & Optimization</h4>
        <p class="step-desc">Deploy models with optimal UI/UX and establish data feedback loops for continuous updates.</p>
      </div>
    </div>
  </div>

<style>
  .flow-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .flow-container {
      flex-direction: row;
      align-items: flex-start;
      gap: 1rem;
    }
  }

  .flow-step {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.5);
    border-radius: 1rem;
    backdrop-filter: blur(8px);
    border: 1px solid rgba(148, 163, 184, 0.2);
    transition: transform 0.3s ease;
  }

  :global(.dark) .flow-step {
    background: rgba(30, 41, 59, 0.5);
    border-color: rgba(71, 85, 105, 0.4);
  }

  .flow-step:hover {
    transform: translateY(-5px);
    background: rgba(255, 255, 255, 0.8);
  }

  :global(.dark) .flow-step:hover {
    background: rgba(30, 41, 59, 0.8);
  }

  .step-icon {
    width: 3.5rem;
    height: 3.5rem;
    background: linear-gradient(135deg, #3b82f6 0%, #06b6d4 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    margin-bottom: 1rem;
    box-shadow: 0 4px 10px rgba(59, 130, 246, 0.3);
  }

  .step-number {
    display: block;
    font-size: 0.875rem;
    font-weight: 700;
    color: #94a3b8;
    margin-bottom: 0.25rem;
  }

  .step-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  :global(.dark) .step-title {
    color: #f1f5f9;
  }

  .step-desc {
    font-size: 0.875rem;
    color: #64748b;
    line-height: 1.6;
  }

  :global(.dark) .step-desc {
    color: #cbd5e1;
  }

  /* Desktop Arrows */
  @media (min-width: 768px) {
    .step-arrow {
      position: absolute;
      top: 2.5rem;
      right: -0.75rem;
      width: 1.5rem;
      height: 2px;
      background: #cbd5e1;
      z-index: 10;
    }
    
    .step-arrow::after {
      content: '';
      position: absolute;
      right: 0;
      top: -3px;
      width: 6px;
      height: 6px;
      border-top: 2px solid #cbd5e1;
      border-right: 2px solid #cbd5e1;
      transform: rotate(45deg);
    }

    :global(.dark) .step-arrow,
    :global(.dark) .step-arrow::after {
      background: #475569;
      border-color: #475569;
    }

    /* Hide arrow for last item */
    .flow-step:last-child .step-arrow {
      display: none;
    }
  }

  /* Mobile Arrows (Vertical) */
  @media (max-width: 767px) {
    .step-arrow {
      position: absolute;
      bottom: -1.25rem;
      left: 50%;
      width: 2px;
      height: 1.5rem;
      background: #cbd5e1;
      transform: translateX(-50%);
      z-index: 10;
    }

    .step-arrow::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: -3px;
      width: 6px;
      height: 6px;
      border-bottom: 2px solid #cbd5e1;
      border-right: 2px solid #cbd5e1;
      transform: rotate(45deg);
    }

    :global(.dark) .step-arrow,
    :global(.dark) .step-arrow::after {
      background: #475569;
      border-color: #475569;
    }

     .flow-step:last-child .step-arrow {
      display: none;
    }
  }

<style>
  .tech-block {
    margin-bottom: 4rem;
    padding: 2.5rem;
    background: var(--block-bg, #ffffff);
    border-radius: 1.5rem;
    box-shadow: 0 4px 20px var(--block-shadow, rgba(0, 0, 0, 0.06));
  }

  :global(.dark) .tech-block {
    --block-bg: rgba(30, 41, 59, 0.6);
    --block-shadow: rgba(0, 0, 0, 0.3);
  }

  .block-title {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 2rem;
    color: var(--title-color, #0f172a);
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  :global(.dark) .block-title {
    --title-color: #f1f5f9;
  }

  .story-step {
    padding: 1.5rem;
    background: var(--step-bg, #f8fafc);
    border-radius: 1rem;
    border-left: 4px solid #667eea;
  }

  :global(.dark) .story-step {
    --step-bg: rgba(15, 23, 42, 0.6);
  }

  .story-step h4 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--step-title, #1e293b);
  }

  :global(.dark) .story-step h4 {
    --step-title: #f1f5f9;
  }

  .story-step p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--step-text, #64748b);
  }

  :global(.dark) .story-step p {
    --step-text: #94a3b8;
  }
</style>
