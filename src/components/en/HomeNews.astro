---
const newsItems = [
  {
    date: "Jan 21, 2026",
    category: "Announcement",
    title: "Website Relaunch"
  }
];
---

<section class="py-24 bg-slate-900 text-white relative overflow-hidden" id="news">
  <!-- Decorative background -->
  <div class="absolute inset-0 pointer-events-none opacity-20">
    <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-gradient-to-tl from-blue-900 to-transparent rounded-full blur-[100px]"></div>
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 border-b border-white/10 pb-8">
      <div>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-2">News</h2>
        <p class="text-slate-400">Latest Updates</p>
      </div>

    </div>

    <div class="space-y-6">
      {newsItems.map((item) => (
        <div class="block">
          <div class="flex flex-col md:flex-row md:items-center py-6 border-b border-white/5">
            <div class="md:w-48 flex-shrink-0 mb-2 md:mb-0">
              <span class="text-sm text-slate-400 font-mono">{item.date}</span>
              <span class="ml-4 text-xs font-semibold px-2 py-1 rounded bg-white/10 text-white/80">
                {item.category}
              </span>
            </div>
            <div class="flex-grow">
              <h3 class="text-lg md:text-xl font-medium text-slate-200">
                {item.title}
              </h3>
            </div>
          </div>
        </div>
      ))}
    </div>


  </div>
</section>
