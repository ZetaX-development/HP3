---
---

<section class="recruitment-section rounded-3xl">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4 text-slate-900 dark:text-white tracking-tight" data-mos="fade-down">
        Open Positions
      </h2>
      <div class="h-1 w-24 bg-gradient-to-r from-blue-500 to-teal-400 mx-auto rounded-full"></div>
    </div>
    
    <div class="grid md:grid-cols-2 gap-8 max-w-6xl mx-auto">
      
      <!-- Position 1: Algorithm Engineer (Cool Theme) -->
      <div class="group relative rounded-3xl overflow-hidden p-[1px] bg-gradient-to-br from-indigo-200 via-blue-200 to-cyan-200 dark:from-indigo-800 dark:via-blue-800 dark:to-cyan-800 transition-all hover:scale-[1.01] hover:shadow-2xl hover:shadow-cyan-500/20">
        <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-indigo-500 via-blue-500 to-cyan-500 opacity-0 group-hover:opacity-10 transition-opacity duration-500"></div>
        
        <div class="relative h-full bg-white dark:bg-slate-900/95 backdrop-blur-sm rounded-[23px] overflow-hidden flex flex-col">
          <!-- Header -->
          <div class="p-8 pb-6 border-b border-slate-100 dark:border-slate-800 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500/10 rounded-full blur-3xl -mr-16 -mt-16"></div>
            
            <div class="relative z-10">
              <h3 class="text-2xl font-bold mb-2 flex items-center gap-3">
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-cyan-500 dark:from-indigo-400 dark:to-cyan-300">
                  Algorithm Engineer
                </span>
              </h3>
              <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
                Developing novel algorithms to solve complex problems
              </p>
            </div>
          </div>
          
          <!-- Content -->
          <div class="p-8 pt-6 space-y-8 flex-grow flex flex-col">
            <!-- MUST -->
            <div>
              <h4 class="flex items-center text-sm font-bold text-slate-400 uppercase tracking-wider mb-4">
                <span class="w-2 h-2 rounded-full bg-blue-500 mr-2"></span>
                Core Requirements
              </h4>
              <ul class="space-y-3">
                {[
                  "Python Proficiency",
                  "Experience with ML/DL frameworks (PyTorch, TensorFlow, etc.)",
                  "Statistical Analysis"
                ].map((item) => (
                  <li class="flex items-start text-slate-700 dark:text-slate-300">
                    <svg class="w-5 h-5 text-blue-500 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- NICE -->
            <div class="flex-grow">
              <h4 class="flex items-center text-sm font-bold text-slate-400 uppercase tracking-wider mb-4">
                <span class="w-2 h-2 rounded-full bg-indigo-500 mr-2"></span>
                Preferred Qualifications
              </h4>
              <ul class="space-y-3">
                {[
                  "Predictive Algorithms / Mathematical Optimization",
                  "Quantum Chemistry / Physics Simulation",
                  "Quantum Machine Learning / Quantum Gates",
                  "Track record of academic publications",
                  "SHAP/XAI Interpretation / QRC Implementation Experience",
                  "Knowledge of Reservoir Computing"
                ].map((item) => (
                  <li class="flex items-start text-slate-700 dark:text-slate-300">
                    <svg class="w-5 h-5 text-indigo-400 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>


          </div>
        </div>
      </div>
      
      <!-- Position 2: Sales (Warm Theme) -->
      <div class="group relative rounded-3xl overflow-hidden p-[1px] bg-gradient-to-br from-orange-200 via-rose-200 to-pink-200 dark:from-orange-800 dark:via-rose-800 dark:to-pink-800 transition-all hover:scale-[1.01] hover:shadow-2xl hover:shadow-orange-500/20">
        <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-orange-500 via-rose-500 to-pink-500 opacity-0 group-hover:opacity-10 transition-opacity duration-500"></div>
        
        <div class="relative h-full bg-white dark:bg-slate-900/95 backdrop-blur-sm rounded-[23px] overflow-hidden flex flex-col">
          <!-- Header -->
          <div class="p-8 pb-6 border-b border-slate-100 dark:border-slate-800 relative overflow-hidden">
             <div class="absolute top-0 right-0 w-32 h-32 bg-orange-500/10 rounded-full blur-3xl -mr-16 -mt-16"></div>

            <div class="relative z-10">
              <h3 class="text-2xl font-bold mb-2 flex items-center gap-3">
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-pink-500 dark:from-orange-400 dark:to-rose-400">
                  Sales
                </span>
              </h3>
              <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
                Event & Trade Show Sales / Consultative Sales
              </p>
            </div>
          </div>
          
          <!-- Content -->
          <div class="p-8 pt-6 space-y-8 flex-grow flex flex-col">
            <!-- MUST -->
            <div class="flex-grow">
              <h4 class="flex items-center text-sm font-bold text-slate-400 uppercase tracking-wider mb-4">
                <span class="w-2 h-2 rounded-full bg-orange-500 mr-2"></span>
                Core Requirements
              </h4>
              <ul class="space-y-3">
                {[
                  "Experience at a technology company or AI startup",
                  "Experience in client proposals and negotiations"
                ].map((item) => (
                  <li class="flex items-start text-slate-700 dark:text-slate-300">
                    <svg class="w-5 h-5 text-orange-500 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            


          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .recruitment-section {
    padding: 5rem 0;
    background: var(--section-bg, linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(240, 244, 248, 1) 100%));
  }

  :global(.dark) .recruitment-section {
    --section-bg: linear-gradient(180deg, rgba(30, 41, 59, 1) 0%, rgba(15, 23, 42, 1) 100%);
  }



  .positions-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .positions-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .position-card {
    background: var(--card-bg, #ffffff);
    border-radius: 1.5rem;
    padding: 2.5rem;
    box-shadow: 0 8px 30px var(--card-shadow, rgba(0, 0, 0, 0.08));
    border: 1px solid var(--card-border, rgba(102, 126, 234, 0.15));
    transition: all 0.4s ease;
  }

  :global(.dark) .position-card {
    --card-bg: rgba(30, 41, 59, 0.6);
    --card-shadow: rgba(0, 0, 0, 0.3);
    --card-border: rgba(255, 255, 255, 0.1);
  }

  .position-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px var(--hover-shadow, rgba(102, 126, 234, 0.15));
    border-color: rgba(102, 126, 234, 0.5);
  }

  :global(.dark) .position-card:hover {
    --hover-shadow: rgba(102, 126, 234, 0.25);
  }

  .position-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid var(--border-color, rgba(102, 126, 234, 0.2));
  }

  :global(.dark) .position-header {
    --border-color: rgba(102, 126, 234, 0.3);
  }

  .position-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.4;
    word-wrap: break-word;
  }

  .position-tagline {
    font-size: 1.05rem;
    color: var(--tagline-color, #475569);
    line-height: 1.6;
  }

  :global(.dark) .position-tagline {
    --tagline-color: #cbd5e1;
  }

  .content-subtitle {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--subtitle-color, #334155);
    margin: 1.75rem 0 1rem;
    line-height: 1.4;
  }

  :global(.dark) .content-subtitle {
    --subtitle-color: #e2e8f0;
  }

  .content-list,
  .skills-list {
    list-style: none;
    padding-left: 0;
    margin: 1rem 0;
  }

  .content-list li,
  .skills-list li {
    padding: 0.75rem 0 0.75rem 1.75rem;
    position: relative;
    color: var(--list-color, #334155);
    line-height: 1.7;
  }

  :global(.dark) .content-list li,
  :global(.dark) .skills-list li {
    --list-color: #e2e8f0;
  }

  .content-list li::before {
    content: "○";
    position: absolute;
    left: 0;
    color: #667eea;
    font-weight: bold;
  }

  .skills-list.must li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #667eea;
    font-weight: bold;
  }

  .skills-list.nice li::before {
    content: "+";
    position: absolute;
    left: 0;
    color: #764ba2;
    font-weight: bold;
  }

  .kpi-list {
    list-style: none;
    padding-left: 0;
    margin: 1rem 0;
  }

  .kpi-list li {
    padding: 0.75rem 0 0.75rem 1.75rem;
    position: relative;
    color: var(--list-color, #334155);
    line-height: 1.7;
  }

  :global(.dark) .kpi-list li {
    --list-color: #e2e8f0;
  }

  .kpi-list li::before {
    content: "★";
    position: absolute;
    left: 0;
    color: #f59e0b;
    font-weight: bold;
  }

  @media (max-width: 768px) {
    .recruitment-section {
      padding: 3rem 0;
    }



    .position-card {
      padding: 2rem;
    }

    .position-title {
      font-size: 1.25rem;
    }

    .content-subtitle {
      font-size: 1.1rem;
    }

    .content-list li,
    .skills-list li {
      font-size: 0.95rem;
    }
  }
</style>
