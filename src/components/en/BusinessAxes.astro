---
---

<section class="py-24 bg-slate-50 dark:bg-slate-900 relative overflow-hidden">
  <div class="container mx-auto px-4 relative z-10">
    
    <div class="flex flex-col lg:flex-row justify-center items-center gap-8 lg:gap-24">
      <!-- AI Solution Circle -->
      <a href="/en/business/ai-solution" class="group relative w-72 h-72 md:w-96 md:h-96 rounded-full flex flex-col justify-center items-center text-center p-8 transition-all duration-500 hover:scale-105">
        <!-- Background/Border Effects -->
        <div class="absolute inset-0 rounded-full border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800/50 backdrop-blur-sm shadow-xl group-hover:shadow-blue-500/30 group-hover:border-blue-400 group-hover:bg-slate-50 dark:group-hover:bg-slate-800 transition-all duration-500"></div>
        <div class="absolute inset-0 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-br from-blue-500/10 to-transparent pointer-events-none"></div>
        
        <!-- Content -->
        <div class="relative z-10 flex flex-col items-center gap-4">
          <div class="w-16 h-1 bg-gradient-to-r from-blue-500 to-cyan-400 rounded-full group-hover:w-24 transition-all duration-500"></div>
          <h3 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-blue-600 group-hover:to-cyan-500 transition-all duration-500">
            AI Solutions
          </h3>
          <p class="text-slate-500 dark:text-slate-400 text-lg md:text-xl font-medium">Custom AI Development</p>
          <p class="text-slate-400 dark:text-slate-500 text-base md:text-lg mt-2 opacity-80 group-hover:opacity-100 transition-opacity">
            Unlocking Value<br/>through Deep Tech
          </p>
          
          <!-- Arrow Icon -->
          <div class="mt-4 p-2 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-400 group-hover:bg-blue-500 group-hover:text-white transition-all duration-300 transform group-hover:translate-x-1">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </div>
        </div>
      </a>

      <!-- Connection Line (Desktop) -->
      <div class="hidden lg:flex flex-col items-center justify-center opacity-30">
        <div class="w-24 h-[1px] bg-gradient-to-r from-blue-500 to-violet-500"></div>
        <div class="w-2 h-2 rounded-full bg-slate-400 my-1"></div>
        <div class="w-24 h-[1px] bg-gradient-to-r from-violet-500 to-blue-500 transform rotate-180"></div>
      </div>

      <!-- PRC Circle -->
      <a href="/en/business/prc" class="group relative w-72 h-72 md:w-96 md:h-96 rounded-full flex flex-col justify-center items-center text-center p-8 transition-all duration-500 hover:scale-105">
        <!-- Background/Border Effects -->
        <div class="absolute inset-0 rounded-full border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800/50 backdrop-blur-sm shadow-xl group-hover:shadow-violet-500/30 group-hover:border-violet-400 group-hover:bg-slate-50 dark:group-hover:bg-slate-800 transition-all duration-500"></div>
        <div class="absolute inset-0 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-br from-violet-500/10 to-transparent pointer-events-none"></div>
        
        <!-- Content -->
        <div class="relative z-10 flex flex-col items-center gap-4">
          <div class="w-16 h-1 bg-gradient-to-r from-violet-500 to-fuchsia-400 rounded-full group-hover:w-24 transition-all duration-500"></div>
          <h3 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-violet-600 group-hover:to-fuchsia-500 transition-all duration-500">
            PRC
          </h3>
          <p class="text-slate-500 dark:text-slate-400 text-lg md:text-xl font-medium">Photonics<br>Reservoir Computing</p>
          <p class="text-slate-400 dark:text-slate-500 text-base md:text-lg mt-2 opacity-80 group-hover:opacity-100 transition-opacity">
            Next-Gen Ultra-Fast,<br/>Low-Power AI
          </p>
          
          <!-- Arrow Icon -->
          <div class="mt-4 p-2 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-400 group-hover:bg-violet-500 group-hover:text-white transition-all duration-300 transform group-hover:translate-x-1">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </div>
        </div>
      </a>

    </div>
  </div>
</section>
