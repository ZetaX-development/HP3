---
/**
 * Wave Highlight Title Component
 * Displays a title with a pink gradient wave animation that flows left-to-right
 * Animation triggers on scroll into view (once)
 */
interface Props {
  title: string;
  className?: string;
}

const { title, className = "text-3xl md:text-4xl font-bold" } = Astro.props;
---

<div class={`wave-title-wrapper ${className}`} data-wave-title>
  <h2 class="wave-title" data-mos="fade-up">
    <span class="wave-text">{title}</span>
    <canvas class="wave-canvas" data-wave-canvas></canvas>
  </h2>
</div>

<script>
  interface WaveTitleElement extends HTMLElement {
    hasAnimated?: boolean;
  }

  function initWaveAnimation(element: WaveTitleElement) {
    if (element.hasAnimated) return;

    const canvas = element.querySelector(
      "[data-wave-canvas]"
    ) as HTMLCanvasElement | null;
    const textSpan = element.querySelector(".wave-text") as HTMLElement | null;

    if (!canvas || !textSpan) return;

    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    // Setup canvas size to match text
    const updateCanvasSize = () => {
      const rect = textSpan.getBoundingClientRect();
      canvas.width = textSpan.offsetWidth;
      canvas.height = textSpan.offsetHeight;
    };

    updateCanvasSize();
    window.addEventListener("resize", updateCanvasSize);

    const duration = 1500; // 1.5 seconds
    const startTime = Date.now();

    const neonGradient = [
      "#ff1493", // Deep Pink
      "#ff69b4", // Hot Pink
      "#ff00ff", // Magenta
      "#ff1493", // Back to Deep Pink
    ];

    function drawWave() {
      const elapsed = Date.now() - startTime;
      const progress = elapsed / duration;

      // Clear canvas
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      if (progress > 1) {
        element.hasAnimated = true;
        return;
      }

      // Wave parameters
      const waveHeight = canvas.height * 0.4;
      const wavelength = canvas.width * 0.3;
      const waveSpeed = canvas.width * progress;

      // Draw wave glow (outer layer for glow effect)
      ctx.strokeStyle = `rgba(255, 20, 147, ${0.3 * (1 - progress)})`;
      ctx.lineWidth = 8;
      ctx.lineCap = "round";
      ctx.lineJoin = "round";
      ctx.shadowColor = "#ff1493";
      ctx.shadowBlur = 20;

      // Main wave line with gradient
      const gradient = ctx.createLinearGradient(0, 0, canvas.width, 0);
      gradient.addColorStop(0, "rgba(255, 20, 147, 0)");
      gradient.addColorStop(0.3, "rgba(255, 105, 180, 0.8)");
      gradient.addColorStop(0.5, "rgba(255, 0, 255, 1)");
      gradient.addColorStop(0.7, "rgba(255, 105, 180, 0.8)");
      gradient.addColorStop(1, "rgba(255, 20, 147, 0)");

      ctx.strokeStyle = gradient;
      ctx.lineWidth = 3;
      ctx.shadowBlur = 15;

      ctx.beginPath();

      // Draw wave path with sine wave
      for (let x = 0; x < canvas.width; x += 2) {
        const distFromWave = Math.abs(x - waveSpeed);
        const waveAmount = Math.sin(
          ((x - waveSpeed) / wavelength) * Math.PI * 2
        );
        const yOffset = (waveHeight * waveAmount * (1 - progress / 2)) / 2;

        // Wave spreads out as it progresses
        const spread = 1 - Math.abs(x - waveSpeed) / (canvas.width * 0.5);
        const yPos =
          canvas.height / 2 + yOffset * Math.max(0, spread * 1.5);

        if (x === 0) {
          ctx.moveTo(x, yPos);
        } else {
          ctx.lineTo(x, yPos);
        }
      }

      ctx.stroke();

      // Draw highlight box that follows the wave
      const highlightWidth = wavelength * 1.2;
      const highlightX = waveSpeed - highlightWidth / 2;

      const hlGradient = ctx.createLinearGradient(
        highlightX,
        0,
        highlightX + highlightWidth,
        0
      );
      hlGradient.addColorStop(0, "rgba(255, 20, 147, 0)");
      hlGradient.addColorStop(0.5, `rgba(255, 0, 255, ${0.4 * (1 - progress)})`);
      hlGradient.addColorStop(1, "rgba(255, 20, 147, 0)");

      ctx.fillStyle = hlGradient;
      ctx.shadowBlur = 25;
      ctx.shadowColor = "#ff1493";
      ctx.fillRect(highlightX, 0, highlightWidth, canvas.height);

      // Continue animation
      if (progress < 1) {
        requestAnimationFrame(drawWave);
      }
    }

    drawWave();
  }

  // Intersection Observer to trigger animation when element is visible
  function setupWaveAnimation() {
    const elements = document.querySelectorAll("[data-wave-title]");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const element = entry.target as WaveTitleElement;
            initWaveAnimation(element);
            observer.unobserve(element);
          }
        });
      },
      { threshold: 0.5 }
    );

    elements.forEach((element) => {
      observer.observe(element);
    });
  }

  // Initialize on page load
  setupWaveAnimation();

  // Reinitialize after view transitions
  document.addEventListener("astro:after-swap", setupWaveAnimation);
</script>

<style>
  .wave-title-wrapper {
    position: relative;
  }

  .wave-title {
    position: relative;
    display: inline-block;
    margin: 0;
    font-weight: bold;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .wave-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .wave-text {
    position: relative;
    z-index: 1;
    display: inline-block;
  }
</style>
