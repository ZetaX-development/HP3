---
import MobileNav from "@components/Nav/MobileNav.astro";
---
<!DOCTYPE html>
<html lang="ja" data-lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <title>Factory Hub — 製造業務統合管理プラットフォーム | ZetaX</title>
  <meta name="description" content="Factory Hub は製造業の受注・納品・顧客管理をひとつのプラットフォームに統合。散在するデータベースを一元化し、二度打ちゼロ・紙ゼロ・AIで業務を変革します。">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #ffffff; --bg-subtle: #f4f6fb; --bg-card: #f9fafb;
      --text-primary: #1a1a2e; --text-secondary: #52606d; --text-dim: #9da5b4;
      --blue-900: #0f1b3d; --blue-800: #152452; --blue-700: #1a3068;
      --blue-600: #1e3a7b; --blue-500: #2b4ea0; --blue-400: #4a6fc4;
      --blue-300: #7b96e0; --blue-200: #b8c8f0; --blue-100: #e8edf8;
      --accent: #2b4ea0; --accent-light: #4a6fc4; --accent-pale: #e8edf8;
      --green: #16a34a; --green-bg: #f0fdf4; --green-border: #bbf7d0;
      --red: #dc2626; --red-bg: #fef2f2; --red-border: #fecaca;
      --border: #e2e6ef; --border-light: #f0f2f6;
      --font-jp: 'Noto Sans JP', sans-serif;
      --font-en: 'Inter', 'Noto Sans JP', sans-serif;
      --ease: cubic-bezier(0.22,1,0.36,1);
    }
    html { scroll-behavior: smooth; font-size: 16px; overflow-x: hidden; }
    body { font-family: var(--font-jp); background: var(--bg); color: var(--text-primary); line-height: 1.8; -webkit-font-smoothing: antialiased; }
    a { color: inherit; text-decoration: none; }

    /* NAV */
    .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; padding: 0 3rem; height: 68px; display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.92); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); transition: box-shadow 0.3s; }
    .nav.elevated { box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
    .nav-logo { font-family: var(--font-en); font-size: 1.15rem; font-weight: 700; letter-spacing: 0.12em; }
    .nav-logo span { color: var(--accent); }
    .nav-right { display: flex; align-items: center; }
    .nav-links { display: flex; list-style: none; font-size: 0.82rem; font-weight: 500; }
    .nav-links > li { position: relative; }
    .nav-links > li > a, .nav-links > li > .nav-dropdown-trigger { display: flex; align-items: center; gap: 4px; height: 68px; padding: 0 1.1rem; color: var(--text-secondary); font-size: 0.82rem; font-weight: 500; border: none; background: none; cursor: pointer; transition: color 0.2s; white-space: nowrap; }
    .nav-links > li > a:hover, .nav-links > li > .nav-dropdown-trigger:hover { color: var(--text-primary); }
    .nav-dropdown-arrow { font-size: 0.55rem; opacity: 0.5; transition: transform 0.2s; }
    .nav-links > li:hover .nav-dropdown-arrow { transform: rotate(180deg); }
    .nav-dropdown { position: absolute; top: calc(100% + 2px); left: 50%; transform: translateX(-50%) translateY(-6px); background: #fff; border: 1px solid var(--border); border-radius: 8px; box-shadow: 0 8px 32px rgba(0,0,0,0.08); padding: 0.6rem 0; min-width: 200px; opacity: 0; visibility: hidden; pointer-events: none; transition: opacity 0.18s var(--ease), transform 0.18s var(--ease); }
    .nav-links > li:hover .nav-dropdown { opacity: 1; visibility: visible; pointer-events: auto; transform: translateX(-50%) translateY(0); }
    .nav-dropdown a { display: block; padding: 0.6rem 1.4rem; font-size: 0.82rem; color: var(--text-secondary); transition: background 0.15s, color 0.15s; white-space: nowrap; }
    .nav-dropdown a:hover { background: var(--bg-subtle); color: var(--accent); }
    .nav-dropdown-divider { height: 1px; background: var(--border-light); margin: 0.4rem 0; }
    .nav-dropdown-label { padding: 0.5rem 1.4rem 0.2rem; font-family: var(--font-en); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-dim); }
    .lang-toggle { display: flex; align-items: center; background: var(--bg-card); border-radius: 20px; padding: 3px; margin-left: 1.4rem; border: 1px solid var(--border); }
    .lang-btn { font-family: var(--font-en); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em; padding: 5px 13px; border-radius: 16px; border: none; cursor: pointer; background: transparent; color: var(--text-dim); transition: all 0.2s; }
    .lang-btn.active { background: var(--accent); color: #fff; }
    .nav-cta { font-family: var(--font-jp); font-size: 0.82rem; font-weight: 600; padding: 9px 22px; border-radius: 6px; background: var(--accent); color: #fff; margin-left: 1.2rem; transition: background 0.2s, transform 0.2s; white-space: nowrap; }
    .nav-cta:hover { background: var(--accent-light); transform: translateY(-1px); }
    @media (max-width: 768px) { .nav-links, .nav-cta, .lang-toggle { display: none; } .nav { padding: 0 1.5rem; } }

    /* BASE */
    .container { max-width: 1080px; margin: 0 auto; padding: 0 2.5rem; }
    .reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.7s var(--ease), transform 0.7s var(--ease); }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .d1 { transition-delay: 0.1s; } .d2 { transition-delay: 0.2s; } .d3 { transition-delay: 0.3s; } .d4 { transition-delay: 0.4s; }
    @media (max-width: 768px) { .container { padding: 0 1.5rem; } .section-title { font-size: 1.3rem; } .section-sub { font-size: 0.85rem; } }
    @media (max-width: 520px) { .footer-inner { flex-direction: column; text-align: center; } .footer-nav { justify-content: center; } }
    .section-title { font-size: clamp(1.5rem, 2.6vw, 2rem); font-weight: 700; line-height: 1.4; color: var(--text-primary); text-align: center; }
    .section-sub { font-size: 0.92rem; color: var(--text-secondary); line-height: 2; text-align: center; margin-top: 0.6rem; }

    /* ═══════════════════════════════════════════
       1. HERO
       ═══════════════════════════════════════════ */
    .hero {
      background: linear-gradient(160deg, #050d1f 0%, var(--blue-900) 30%, var(--blue-700) 60%, var(--blue-500) 100%);
      padding: 68px 0 0; position: relative; overflow: hidden; min-height: 100vh;
      display: flex; flex-direction: column; justify-content: center;
    }
    .hero::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(43,78,160,0.25) 0%, transparent 70%);
      pointer-events: none;
    }
    @keyframes float-up { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-18px); } }
    @keyframes float-down { 0%,100% { transform: translateY(0); } 50% { transform: translateY(14px); } }
    @keyframes pulse-ring { 0% { transform: translate(-50%,-50%) scale(0.8); opacity: 0.6; } 100% { transform: translate(-50%,-50%) scale(1.8); opacity: 0; } }
    @keyframes grid-slide { 0% { background-position: 0 0; } 100% { background-position: 40px 40px; } }
    @keyframes hero-fade-up { 0% { opacity: 0; transform: translateY(30px); } 100% { opacity: 1; transform: translateY(0); } }
    @keyframes hero-scale-in { 0% { opacity: 0; transform: scale(0.92); } 100% { opacity: 1; transform: scale(1); } }
    @keyframes glow-pulse { 0%,100% { box-shadow: 0 0 30px rgba(74,111,196,0.3); } 50% { box-shadow: 0 0 50px rgba(74,111,196,0.6); } }
    @keyframes shimmer { 0% { background-position: -200% center; } 100% { background-position: 200% center; } }

    .hero-grid-bg {
      position: absolute; inset: 0; pointer-events: none;
      background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 40px 40px;
      animation: grid-slide 20s linear infinite;
    }
    .hero-orb {
      position: absolute; border-radius: 50%; pointer-events: none;
      filter: blur(60px);
    }
    .hero-orb-1 {
      width: 400px; height: 400px; top: -80px; right: -60px;
      background: radial-gradient(circle, rgba(74,111,196,0.35) 0%, transparent 70%);
      animation: float-up 8s ease-in-out infinite;
    }
    .hero-orb-2 {
      width: 300px; height: 300px; bottom: -60px; left: -40px;
      background: radial-gradient(circle, rgba(43,78,160,0.3) 0%, transparent 70%);
      animation: float-down 10s ease-in-out infinite;
    }
    .hero-orb-3 {
      width: 200px; height: 200px; top: 30%; left: 15%;
      background: radial-gradient(circle, rgba(123,150,224,0.15) 0%, transparent 70%);
      animation: float-up 12s ease-in-out infinite 2s;
    }
    .hero-ring {
      position: absolute; top: 50%; left: 50%;
      width: 500px; height: 500px; border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.06);
      animation: pulse-ring 6s ease-out infinite;
      pointer-events: none;
    }
    .hero-ring-2 {
      position: absolute; top: 50%; left: 50%;
      width: 500px; height: 500px; border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.04);
      animation: pulse-ring 6s ease-out infinite 3s;
      pointer-events: none;
    }

    .hero-content {
      position: relative; z-index: 2;
      display: grid; grid-template-columns: 1fr 1fr; gap: 4rem;
      align-items: center; padding: 4rem 0 5rem;
    }
    .hero-text { animation: hero-fade-up 1s var(--ease) both; }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 6px;
      font-family: var(--font-en); font-size: 0.7rem; font-weight: 700;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--blue-300); padding: 6px 16px;
      border: 1px solid rgba(74,111,196,0.3); border-radius: 20px;
      background: rgba(74,111,196,0.1); margin-bottom: 1.6rem;
      backdrop-filter: blur(4px);
    }
    .hero-badge-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--blue-300); animation: glow-pulse 2s ease-in-out infinite;
      box-shadow: 0 0 8px var(--blue-300);
    }
    .hero h1 {
      font-family: var(--font-en); font-size: clamp(2.6rem, 5.5vw, 4rem);
      font-weight: 900; color: #fff; letter-spacing: -0.02em;
      line-height: 1.08; margin-bottom: 0.6rem;
    }
    .hero h1 .hero-h1-gradient {
      background: linear-gradient(135deg, #fff 0%, var(--blue-200) 50%, var(--blue-300) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-subtitle {
      font-size: clamp(1rem, 1.8vw, 1.25rem); font-weight: 600;
      color: rgba(255,255,255,0.6); margin-bottom: 1.6rem; line-height: 1.6;
    }
    .hero-desc {
      font-size: 0.9rem; color: rgba(255,255,255,0.35); line-height: 2;
      margin-bottom: 2.2rem; max-width: 420px;
    }
    .hero-actions { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
    .hero-cta {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--font-jp); font-size: 0.95rem; font-weight: 700;
      padding: 15px 36px; border-radius: 8px;
      background: linear-gradient(135deg, #fff 0%, #e8edf8 100%);
      color: var(--blue-800);
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    }
    .hero-cta:hover { transform: translateY(-3px); box-shadow: 0 8px 32px rgba(0,0,0,0.25); }
    .hero-cta-arrow {
      transition: transform 0.2s;
    }
    .hero-cta:hover .hero-cta-arrow { transform: translateX(4px); }
    .hero-cta-ghost {
      display: inline-flex; align-items: center; gap: 6px;
      font-family: var(--font-jp); font-size: 0.88rem; font-weight: 500;
      padding: 13px 24px; border-radius: 8px;
      border: 1px solid rgba(255,255,255,0.15); color: rgba(255,255,255,0.7);
      background: rgba(255,255,255,0.04); backdrop-filter: blur(4px);
      transition: border-color 0.2s, color 0.2s, background 0.2s;
    }
    .hero-cta-ghost:hover { border-color: rgba(255,255,255,0.3); color: #fff; background: rgba(255,255,255,0.08); }
    .hero-powered {
      display: inline-block; font-family: var(--font-en); font-size: 0.68rem; font-weight: 600;
      letter-spacing: 0.08em; color: rgba(255,255,255,0.2); margin-top: 1.6rem;
    }

    .hero-visual {
      animation: hero-scale-in 1.2s var(--ease) 0.3s both;
      position: relative;
    }
    .hero-mockup {
      background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
      border-radius: 14px; padding: 1.4rem; backdrop-filter: blur(12px);
      animation: glow-pulse 4s ease-in-out infinite;
    }
    .hero-mockup-bar { display: flex; align-items: center; gap: 6px; margin-bottom: 1.2rem; }
    .hm-dot { width: 8px; height: 8px; border-radius: 50%; }
    .hm-dot-r { background: #ff5f57; } .hm-dot-y { background: #febc2e; } .hm-dot-g { background: #28c840; }
    .hm-title {
      font-family: var(--font-en); font-size: 0.68rem; font-weight: 700;
      color: rgba(255,255,255,0.4); letter-spacing: 0.06em; margin-left: 8px;
    }
    .hero-mockup-body { display: flex; flex-direction: column; gap: 0.6rem; }
    .hm-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 0.7rem 1rem; border-radius: 8px;
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06);
      transition: background 0.3s;
    }
    .hm-row:hover { background: rgba(255,255,255,0.08); }
    .hm-label { font-size: 0.78rem; color: rgba(255,255,255,0.5); }
    .hm-val { font-family: var(--font-en); font-size: 0.82rem; font-weight: 700; color: #fff; }
    .hm-badge {
      font-family: var(--font-en); font-size: 0.62rem; font-weight: 700;
      padding: 3px 10px; border-radius: 4px;
    }
    .hm-badge-ok { background: rgba(22,163,74,0.2); color: #4ade80; }
    .hm-badge-proc { background: rgba(74,111,196,0.2); color: var(--blue-300); }
    .hm-badge-pending { background: rgba(251,191,36,0.2); color: #fbbf24; }
    .hm-progress {
      height: 4px; border-radius: 2px; background: rgba(255,255,255,0.08);
      margin-top: 0.4rem; overflow: hidden;
    }
    .hm-progress-fill {
      height: 100%; border-radius: 2px;
      background: linear-gradient(90deg, var(--blue-400), var(--blue-300));
    }

    .hero-float-card {
      position: absolute; border-radius: 10px; padding: 0.8rem 1rem;
      background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1);
      backdrop-filter: blur(12px); z-index: 3; white-space: nowrap;
    }
    .hero-float-1 {
      top: -16px; right: -20px; animation: float-up 5s ease-in-out infinite;
    }
    .hero-float-2 {
      bottom: 20px; left: -30px; animation: float-down 6s ease-in-out infinite 1s;
    }
    .hf-label { font-size: 0.62rem; color: rgba(255,255,255,0.35); margin-bottom: 2px; }
    .hf-val { font-family: var(--font-en); font-size: 1rem; font-weight: 800; color: #fff; }
    .hf-sub { font-size: 0.6rem; color: rgba(74,111,196,0.8); }

    .hero-stat-strip {
      display: flex; justify-content: space-around; padding: 1.2rem 0;
      border-top: 1px solid rgba(255,255,255,0.06);
      margin-top: 2rem; animation: hero-fade-up 1s var(--ease) 0.8s both;
      position: relative; z-index: 2;
    }
    .hero-stat { text-align: center; }
    .hero-stat-val {
      font-family: var(--font-en); font-size: 1.4rem; font-weight: 800; color: #fff;
      background: linear-gradient(135deg, #fff, var(--blue-200));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .hero-stat-label { font-size: 0.68rem; color: rgba(255,255,255,0.3); }

    @media (max-width: 900px) {
      .hero-content { grid-template-columns: 1fr; gap: 2.5rem; text-align: center; padding: 3rem 0 3rem; }
      .hero-text { animation-delay: 0s; }
      .hero-desc { margin-left: auto; margin-right: auto; }
      .hero-actions { justify-content: center; }
      .hero-visual { max-width: 420px; margin: 0 auto; }
      .hero-float-card { display: none; }
      .hero h1 { font-size: clamp(2rem, 8vw, 3rem); }
      .hero { min-height: auto; }
      .hero-stat-strip { flex-wrap: wrap; gap: 1rem; }
      .hero-stat { flex: 0 0 40%; }
    }
    @media (max-width: 520px) {
      .hero-content { padding: 2rem 0 2.5rem; }
      .hero-badge { font-size: 0.6rem; padding: 5px 12px; margin-bottom: 1.2rem; }
      .hero-subtitle { font-size: 1rem; }
      .hero-desc { font-size: 0.82rem; }
      .hero-cta { font-size: 0.88rem; padding: 13px 28px; }
      .hero-cta-ghost { font-size: 0.82rem; padding: 11px 18px; }
      .hero-mockup { padding: 1rem; }
      .hm-row { padding: 0.5rem 0.7rem; }
      .hm-label { font-size: 0.7rem; }
      .hm-val { font-size: 0.72rem; }
    }

    /* ═══════════════════════════════════════════
       2. PAIN — こんな課題、ありませんか？
       ═══════════════════════════════════════════ */
    .pain { padding: 80px 0; background: var(--bg-subtle); }
    .pain-grid {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.2rem; margin-top: 2.5rem;
    }
    .pain-card {
      background: var(--bg); border: 1px solid var(--border); border-radius: 10px;
      padding: 2rem 1.6rem; text-align: center; transition: transform 0.2s, box-shadow 0.2s;
    }
    .pain-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.06); }
    .pain-icon {
      width: 48px; height: 48px; border-radius: 10px; background: var(--accent-pale);
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1rem; font-size: 1.2rem;
    }
    .pain-card h3 { font-size: 0.92rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem; line-height: 1.4; }
    .pain-card p { font-size: 0.78rem; color: var(--text-secondary); line-height: 1.7; }
    @media (max-width: 900px) { .pain-grid { grid-template-columns: repeat(2,1fr); } }
    @media (max-width: 520px) { .pain-grid { grid-template-columns: 1fr; } .pain { padding: 60px 0; } .pain-card { padding: 1.5rem 1.2rem; } }

    /* ═══════════════════════════════════════════
       3. NUMBERS — Factory Hub が全て解決します
       ═══════════════════════════════════════════ */
    .numbers {
      background: linear-gradient(160deg, var(--blue-800) 0%, var(--blue-600) 100%);
      padding: 60px 0;
    }
    .numbers .section-title { color: #fff; margin-bottom: 2.5rem; }
    .numbers-row {
      display: grid; grid-template-columns: repeat(4,1fr); gap: 2rem; text-align: center;
    }
    .numbers-val {
      font-family: var(--font-en); font-size: clamp(2rem, 4vw, 2.8rem);
      font-weight: 800; color: #fff; line-height: 1; margin-bottom: 0.3rem;
    }
    .numbers-unit { font-size: 0.82rem; font-weight: 600; color: var(--blue-300); margin-bottom: 0.2rem; }
    .numbers-label { font-size: 0.76rem; color: rgba(255,255,255,0.4); }
    @media (max-width: 768px) { .numbers-row { grid-template-columns: repeat(2,1fr); gap: 2rem 1rem; } .numbers { padding: 50px 0; } }
    @media (max-width: 520px) { .numbers-val { font-size: 1.8rem; } }

    /* ═══════════════════════════════════════════
       3.5 DEMO — インタラクティブデモ
       ═══════════════════════════════════════════ */
    .demo { padding: 80px 0; background: var(--bg); }
    .demo .section-title { margin-bottom: 0.6rem; }
    .demo .section-sub { margin-bottom: 2.5rem; }
    .demo-frame-wrap {
      position: relative; border-radius: 14px; overflow: hidden;
      border: 1px solid var(--border); box-shadow: 0 12px 48px rgba(0,0,0,0.08);
      background: var(--bg-subtle);
    }
    .demo-frame-bar {
      display: flex; align-items: center; gap: 8px; padding: 10px 16px;
      background: var(--bg-card); border-bottom: 1px solid var(--border);
    }
    .df-dot { width: 10px; height: 10px; border-radius: 50%; }
    .df-dot-r { background: #ff5f57; } .df-dot-y { background: #febc2e; } .df-dot-g { background: #28c840; }
    .df-url {
      flex: 1; margin-left: 8px; padding: 5px 14px; border-radius: 6px;
      background: var(--bg-subtle); border: 1px solid var(--border);
      font-family: var(--font-en); font-size: 0.72rem; color: var(--text-dim);
    }
    .demo-iframe {
      width: 100%; height: 700px; border: none; display: block;
      background: #fff;
    }
    .demo-overlay {
      position: absolute; bottom: 0; left: 0; right: 0;
      height: 80px; pointer-events: none;
      background: linear-gradient(transparent, var(--bg));
    }
    .demo-fullscreen {
