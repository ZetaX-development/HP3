  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #ffffff; --bg-subtle: #f7f8fa; --text-primary: #0d0d14;
      --text-secondary: #52606d; --text-dim: #9da5b4; --accent: #1a3fbf;
      --border: #e4e7ef; --font-jp: 'Noto Sans JP', sans-serif; --font-en: 'Inter', sans-serif;
    }
    html { font-size: 16px; background: var(--bg); }
    body { font-family: var(--font-jp); color: var(--text-primary); line-height: 1.8; -webkit-font-smoothing: antialiased; }
    a { color: inherit; text-decoration: none; }
    .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 0 3rem; height: 68px; display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.97); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); }
    .nav-logo { font-family: var(--font-en); font-size: 1.15rem; font-weight: 700; letter-spacing: 0.12em; }
    .nav-logo span { color: var(--accent); }
    .nav-back { font-family: var(--font-en); font-size: 0.8rem; color: var(--text-secondary); display: flex; align-items: center; gap: 0.4rem; transition: color 0.2s; }
    .nav-back:hover { color: var(--accent); }
    .page-wrap { max-width: 760px; margin: 0 auto; padding: 120px 3rem 100px; }
    .page-label { font-family: var(--font-en); font-size: 0.66rem; font-weight: 700; letter-spacing: 0.25em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }
    .page-label::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: var(--accent); }
    .page-title { font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 700; margin-bottom: 0.5rem; }
    .page-date { font-family: var(--font-en); font-size: 0.78rem; color: var(--text-dim); margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border); }
    .policy-body h2 { font-size: 1.05rem; font-weight: 700; margin: 2.5rem 0 0.8rem; color: var(--text-primary); }
    .policy-body p { font-size: 0.92rem; color: var(--text-secondary); line-height: 2; margin-bottom: 1rem; }
    .policy-body ul { margin: 0.8rem 0 1rem 1.4rem; }
    .policy-body li { font-size: 0.92rem; color: var(--text-secondary); line-height: 1.9; margin-bottom: 0.3rem; }
    .footer-mini { border-top: 1px solid var(--border); padding: 2rem 3rem; text-align: center; font-family: var(--font-en); font-size: 0.74rem; color: var(--text-dim); }
    @media (max-width: 768px) { .nav { padding: 0 1.5rem; } .page-wrap { padding: 100px 1.5rem 80px; } .footer-mini { padding: 2rem 1.5rem; } }
  </style>
</head>
<body>
