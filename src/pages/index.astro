  <script>
    // LANGUAGE
    const langBtns = document.querySelectorAll('.lang-btn');
    let currentLang = 'ja';
    function setLang(lang) {
      currentLang = lang;
      langBtns.forEach(b => b.classList.toggle('active', b.dataset.lang === lang));
      document.documentElement.setAttribute('data-lang', lang);
      document.querySelectorAll('[data-ja][data-en]').forEach(el => {
        const text = lang === 'ja' ? el.dataset.ja : el.dataset.en;
        if (text !== undefined) el.innerHTML = text;
      });
      document.querySelectorAll('input[data-ja-placeholder], textarea[data-ja-placeholder]').forEach(el => {
        el.placeholder = lang === 'ja' ? el.dataset.jaPlaceholder : el.dataset.enPlaceholder;
      });
    }
    langBtns.forEach(b => b.addEventListener('click', () => setLang(b.dataset.lang)));

    // NAV
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => nav.classList.toggle('elevated', window.scrollY > 10), { passive: true });

    // DROPDOWN — close on click outside
    document.addEventListener('click', e => {
      if (!e.target.closest('.nav-links > li')) {
        document.querySelectorAll('.nav-dropdown').forEach(d => {
          d.style.opacity = ''; d.style.visibility = ''; d.style.pointerEvents = '';
        });
      }
    });

    // REVEAL
    const observer = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
    }, { threshold: 0.07, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // TABS
    document.querySelectorAll('.company-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const t = btn.dataset.tab;
        document.querySelectorAll('.company-tab').forEach(b => b.classList.toggle('active', b.dataset.tab === t));
        document.querySelectorAll('.tab-panel').forEach(p => {
          const active = p.id === `tab-${t}`;
          p.classList.toggle('active', active);
          if (active) p.querySelectorAll('.reveal').forEach(el => el.classList.add('visible'));
        });
      });
    });

    // FORM
    async function submitForm(e) {
      e.preventDefault();
      const btn = document.getElementById('contact-submit-btn');
      btn.textContent = currentLang === 'ja' ? '送信中...' : 'Sending...';
      btn.disabled = true;
      await new Promise(r => setTimeout(r, 1000));
      document.getElementById('contactForm').style.display = 'none';
      document.getElementById('formSuccess').style.display = 'block';
    }

    // ANCHOR SCROLL
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', e => {
        const t = document.querySelector(a.getAttribute('href'));
        if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
      });
    });
  </script>

  <!-- HERO KINETIC TYPOGRAPHY (teamLab-inspired, white base) -->
  <script>
    (function () {
      const canvas = document.getElementById('hero-canvas');
      const hero = document.getElementById('hero');
      if (!canvas || !hero) return;

      const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
      const ctx = canvas.getContext('2d', { alpha: false });
      let w = 0, h = 0, dpr = 1, t = 0, raf = null, running = false;
      const mouse = { x: -9999, y: -9999, active: false };

      // ブランドブルーのパレット（白の上で上品に映る範囲だけ）
      const PALETTE = ['26,63,191', '40,86,214', '78,116,235', '120,150,247'];
      const WORD = 'ZetaX';

      let textP = [], flowP = [], blooms = [];

      // ── 擬似ノイズの流れ場（粒子に“息づき”を与える）──
      function field(x, y, time, layer) {
        const s = 0.0016, o = layer * 2.3;
        return (
          Math.sin(x * s + time + o) * 1.2 +
          Math.cos(y * s * 1.3 - time * 0.8 + o) * 1.1 +
          Math.sin((x + y) * s * 0.6 + time * 0.5) * 0.9
        ) * Math.PI;
      }

      // ── オフスクリーンに文字を描いてピクセルをサンプリング → 集合先の座標群 ──
      function sampleWord(word) {
        const off = document.createElement('canvas');
        off.width = Math.max(1, Math.round(w));
        off.height = Math.max(1, Math.round(h));
        const o = off.getContext('2d');
        let fontPx = Math.floor(h * 0.42);
        o.font = '800 ' + fontPx + 'px Inter, "Noto Sans JP", sans-serif';
        const maxW = w * 0.78;
        const tw = o.measureText(word).width;
        if (tw > maxW) {
          fontPx = Math.floor(fontPx * maxW / tw);
          o.font = '800 ' + fontPx + 'px Inter, "Noto Sans JP", sans-serif';
        }
        o.textAlign = 'center';
        o.textBaseline = 'middle';
        o.fillStyle = '#000';
        o.fillText(word, w / 2, h * 0.46);
        const data = o.getImageData(0, 0, off.width, off.height).data;
        const gap = Math.max(3, Math.round(fontPx / 62));
        const pts = [];
        for (let y = 0; y < off.height; y += gap) {
          for (let x = 0; x < off.width; x += gap) {
            if (data[(y * off.width + x) * 4 + 3] > 130) pts.push([x, y]);
          }
        }
        // シャッフルして密度を均一化
        for (let i = pts.length - 1; i > 0; i--) {
          const j = (Math.random() * (i + 1)) | 0;
          const tmp = pts[i]; pts[i] = pts[j]; pts[j] = tmp;
        }
        const cap = w < 640 ? 1100 : 2600;
        return pts.slice(0, cap);
      }

      function buildText(firstTime) {
        const pts = sampleWord(WORD);
        const prev = textP;
        textP = pts.map((pt, i) => {
          const reuse = prev[i];
          const sx = reuse ? reuse.x : (firstTime ? Math.random() * w : w / 2 + (Math.random() - 0.5) * w);
          const sy = reuse ? reuse.y : (firstTime ? Math.random() * h : h / 2 + (Math.random() - 0.5) * h);
          return {
            hx: pt[0], hy: pt[1],
            x: sx, y: sy, vx: 0, vy: 0,
            color: PALETTE[(Math.random() * PALETTE.length) | 0],
            size: 1.0 + Math.random() * 1.3,
            tw: Math.random() * 6.283,
          };
        });
      }

      function buildFlow() {
        const n = Math.round(Math.min(w < 640 ? 80 : 230, (w * h) / 9000));
        flowP = [];
        for (let i = 0; i < n; i++) {
          flowP.push({
            x: Math.random() * w, y: Math.random() * h,
            size: 0.5 + Math.random() * 1.2,
            color: PALETTE[(Math.random() * PALETTE.length) | 0],
            sp: 0.4 + Math.random() * 0.6,
          });
        }
      }

      function resize() {
        const r = hero.getBoundingClientRect();
        if (r.width < 2 || r.height < 2) return;
        dpr = Math.min(devicePixelRatio || 1, 2);
        w = r.width; h = r.height;
        canvas.width = Math.round(w * dpr);
        canvas.height = Math.round(h * dpr);
        canvas.style.width = w + 'px';
        canvas.style.height = h + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        ctx.fillStyle = '#fff'; ctx.fillRect(0, 0, w, h);
        buildText(true); buildFlow();
        canvas.classList.add('ready');
      }

      // クリック/タップで光の花が咲く
      function bloom(x, y) {
        if (blooms.length > 36) return;
        blooms.push({
          x, y, age: 0, max: 46 + Math.random() * 26,
          petals: 6 + ((Math.random() * 4) | 0),
          rot: Math.random() * 6.283,
          color: PALETTE[(Math.random() * PALETTE.length) | 0],
          r: 16 + Math.random() * 22,
        });
      }

      function drawBloom(b) {
        b.age++;
        const p = b.age / b.max;
        const ease = p < 0.6 ? (p / 0.6) : 1;
        const fade = p < 0.6 ? 1 : (1 - (p - 0.6) / 0.4);
        const rad = b.r * ease * (1 + p * 0.5);
        ctx.save();
        ctx.translate(b.x, b.y);
        ctx.rotate(b.rot + p * 0.7);
        for (let i = 0; i < b.petals; i++) {
          ctx.rotate((Math.PI * 2) / b.petals);
          ctx.beginPath();
          ctx.ellipse(rad * 0.55, 0, rad * 0.5, rad * 0.22, 0, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(' + b.color + ',' + (0.10 * fade) + ')';
          ctx.fill();
        }
        ctx.beginPath();
        ctx.arc(0, 0, rad * 0.16, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + b.color + ',' + (0.20 * fade) + ')';
        ctx.fill();
        ctx.restore();
      }

      function step() {
        // 柔らかいクリア（わずかな残光で生命感、文字はほぼ鮮明に保つ）
        ctx.fillStyle = 'rgba(255,255,255,0.30)';
        ctx.fillRect(0, 0, w, h);
        t += 0.0016;

        // カーソルのソフトな光
        if (mouse.active) {
          const g = ctx.createRadialGradient(mouse.x, mouse.y, 0, mouse.x, mouse.y, 150);
          g.addColorStop(0, 'rgba(40,86,214,0.06)');
          g.addColorStop(1, 'rgba(40,86,214,0)');
          ctx.fillStyle = g;
          ctx.beginPath(); ctx.arc(mouse.x, mouse.y, 150, 0, Math.PI * 2); ctx.fill();
        }

        // 背景の流れる塵
        for (const p of flowP) {
          const a = field(p.x, p.y, t, 0);
          p.x += Math.cos(a) * p.sp; p.y += Math.sin(a) * p.sp;
          if (p.x < -10) p.x = w + 10; else if (p.x > w + 10) p.x = -10;
          if (p.y < -10) p.y = h + 10; else if (p.y > h + 10) p.y = -10;
          ctx.fillStyle = 'rgba(' + p.color + ',0.10)';
          ctx.fillRect(p.x, p.y, p.size, p.size);
        }

        // 文字を形づくる粒子（ホームへバネ + カーソルで反発 + 流れでゆらぐ）
        const R = 140, R2 = R * R;
        for (const p of textP) {
          const dx = p.hx - p.x, dy = p.hy - p.y;
          p.vx += dx * 0.013; p.vy += dy * 0.013;
          if (mouse.active) {
            const mx = p.x - mouse.x, my = p.y - mouse.y, d2 = mx * mx + my * my;
            if (d2 < R2) {
              const d = Math.sqrt(d2) || 1, f = 1 - d / R;
              p.vx += (mx / d) * f * 4.4;
              p.vy += (my / d) * f * 4.4;
            }
          }
          const a = field(p.x, p.y, t, 1);
          p.vx += Math.cos(a) * 0.05; p.vy += Math.sin(a) * 0.05;
          p.vx *= 0.85; p.vy *= 0.85;
          p.x += p.vx; p.y += p.vy;
          p.tw += 0.05;
          const tw = 0.78 + 0.22 * Math.sin(p.tw);
          ctx.fillStyle = 'rgba(' + p.color + ',' + (0.9 * tw) + ')';
          ctx.fillRect(p.x, p.y, p.size, p.size);
        }

        // 光の花
        for (let i = blooms.length - 1; i >= 0; i--) {
          drawBloom(blooms[i]);
          if (blooms[i].age > blooms[i].max) blooms.splice(i, 1);
        }

        raf = requestAnimationFrame(step);
      }

      function start() {
        if (running || reduce) return;
        running = true;
        raf = requestAnimationFrame(step);
      }
      function stop() {
        running = false;
        if (raf) cancelAnimationFrame(raf);
        raf = null;
      }

      // 初期化
      resize();
      let resizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(resize, 220);
      });

      // マウス追従 & クリックで開花（hero上のみ）
      hero.addEventListener('pointermove', (e) => {
        const r = hero.getBoundingClientRect();
        mouse.x = e.clientX - r.left;
        mouse.y = e.clientY - r.top;
        mouse.active = true;
      }, { passive: true });
      hero.addEventListener('pointerleave', () => { mouse.active = false; });
      hero.addEventListener('pointerdown', (e) => {
        const r = hero.getBoundingClientRect();
        bloom(e.clientX - r.left, e.clientY - r.top);
      }, { passive: true });

      if (reduce) {
        // モーション抑制時は文字を静的に一度だけ描く
        ctx.fillStyle = '#fff'; ctx.fillRect(0, 0, w, h);
        for (const p of textP) {
          ctx.fillStyle = 'rgba(' + p.color + ',0.85)';
          ctx.fillRect(p.hx, p.hy, p.size, p.size);
        }
        return;
      }

      // heroが画面内にある時だけ描画（省電力）
      if ('IntersectionObserver' in window) {
        new IntersectionObserver((entries) => {
          entries.forEach((en) => (en.isIntersecting ? start() : stop()));
        }, { threshold: 0.01 }).observe(hero);
      } else {
        start();
      }
      document.addEventListener('visibilitychange', () => {
        document.hidden ? stop() : start();
      });
    })();
  </script>

</body>
</html>
