---
import MobileNav from "@components/Nav/MobileNav.astro";
import { getCollection } from "astro:content";

const latestNews = (await getCollection("news", ({ data }) => data.draft !== true))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const fmtDate = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, "0")}.${String(d.getDate()).padStart(2, "0")}`;
---
<!DOCTYPE html>
<html lang="ja" data-lang="ja">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <title>ZetaX — 上流から下流まで。妥協しない、一気通貫。</title>
  <meta name="description" content="ZetaXは東京大学出身エンジニア中心のAI・ITプロフェッショナル集団。戦略立案から実装・保守まで完全内製で一気通貫対応。AI/ITコンサル・開発、セキュリティコンサル、AI研修、ハードウェア開発。">
  <meta property="og:title" content="ZetaX — 上流から下流まで。妥協しない、一気通貫。">
  <meta property="og:description" content="東大発AI・ITプロフェッショナル集団。完全内製、超上流から下流まで一気通貫。">
  <meta property="og:type" content="website">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@200;300;400;500;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script is:inline>
    // INTRO gate: 最初のペイント前に実行。演出を出す時だけ zx-hold を立てる。
    // sessionStorage 不可(プライベートモード等)や reduced-motion では演出なし。
    (function () {
      try {
        if (!sessionStorage.getItem("zxIntroSeen") && !matchMedia("(prefers-reduced-motion: reduce)").matches) {
          document.documentElement.classList.add("zx-hold");
        }
      } catch (e) { /* skip intro */ }
    })();
  </script>
  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #ffffff;
      --bg-subtle: #f7f8fa;
      --bg-card: #f9fafb;
      --text-primary: #0d0d14;
      --text-secondary: #52606d;
      --text-dim: #9da5b4;
      --accent: #1a3fbf;
      --accent-light: #3b5fdf;
      --accent-pale: #eef1fd;
      --border: #e4e7ef;
      --border-light: #f0f2f6;
      --font-jp: 'Noto Sans JP', sans-serif;
      --font-en: 'Inter', 'Noto Sans JP', sans-serif;
      --shadow-sm: 0 1px 4px rgba(0,0,0,0.05);
      --shadow-md: 0 4px 20px rgba(0,0,0,0.07);
      --ease: cubic-bezier(0.22, 1, 0.36, 1);
    }

    html { scroll-behavior: smooth; font-size: 16px; background: var(--bg); overflow-x: hidden; }
    body { font-family: var(--font-jp); background: var(--bg); color: var(--text-primary); line-height: 1.8; -webkit-font-smoothing: antialiased; }
    a { color: inherit; text-decoration: none; }

    /* ─── INTRO（初回のみのローディング演出） ─── */
    #zx-intro { display: none; position: fixed; inset: 0; z-index: 20000; background: var(--bg); align-items: center; justify-content: center; }
    html.zx-hold #zx-intro { display: flex; }
    #zx-intro .zxi-rule {
      position: absolute; left: 50%; top: 0; width: 1px; height: 100%;
      background: rgba(13,13,20,0.35);
      transform: scaleY(0); transform-origin: center top;
    }
    #zx-intro.zxi-s1 .zxi-rule { transform: scaleY(1); transition: transform 0.4s var(--ease); }
    #zx-intro .zxi-mark {
      position: relative;
      font-family: var(--font-en); font-weight: 700;
      font-size: clamp(2rem, 6vw, 3.6rem);
      letter-spacing: 0.3em; padding: 0.25em 0 0.25em 0.3em; /* 左padding=字間ぶんで光学センター */
      color: var(--text-primary); background: var(--bg); /* 背後の縦罫をマスク */
      clip-path: inset(100% 0 0 0);
    }
    #zx-intro .zxi-mark span { color: var(--accent); }
    #zx-intro.zxi-s2 .zxi-mark { clip-path: inset(0 0 0 0); transition: clip-path 0.5s var(--ease); }
    #zx-intro.zxi-done { opacity: 0; pointer-events: none; transition: opacity 0.45s ease; }
    /* 幕が明けるまでヒーローの fadeUp を一時停止（二重再生防止） */
    html.zx-hold .hero * { animation-play-state: paused !important; }

    /* ─── NAV ─── */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      padding: 0 3rem; height: 68px;
      display: flex; justify-content: space-between; align-items: center;
      background: rgba(255,255,255,0.97);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
      transition: box-shadow 0.3s ease;
    }
    .nav.elevated { box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
    .nav-logo { font-family: var(--font-en); font-size: 1.15rem; font-weight: 700; letter-spacing: 0.12em; color: var(--text-primary); }
    .nav-logo span { color: var(--accent); }
    .nav-right { display: flex; align-items: center; gap: 0; }
    .nav-links { display: flex; gap: 0; list-style: none; font-family: var(--font-jp); font-size: 0.82rem; font-weight: 500; }

    /* flat link */
    .nav-links > li { position: relative; }
    .nav-links > li > a,
    .nav-links > li > .nav-dropdown-trigger {
      display: flex; align-items: center; gap: 4px;
      height: 68px; padding: 0 1.1rem;
      color: var(--text-secondary);
      font-family: var(--font-jp); font-size: 0.82rem; font-weight: 500;
      border: none; background: none; cursor: pointer;
      transition: color 0.2s;
      white-space: nowrap;
    }
    .nav-links > li > a:hover,
    .nav-links > li > .nav-dropdown-trigger:hover,
    .nav-links > li:hover > .nav-dropdown-trigger { color: var(--text-primary); }
    .nav-dropdown-arrow { font-size: 0.55rem; opacity: 0.5; transition: transform 0.2s; }
    .nav-links > li:hover .nav-dropdown-arrow { transform: rotate(180deg); }

    /* dropdown panel */
    .nav-dropdown {
      position: absolute; top: calc(100% + 2px); left: 50%; transform: translateX(-50%);
      background: #fff; border: 1px solid var(--border); border-radius: 8px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.08); padding: 0.6rem 0;
      min-width: 200px; opacity: 0; visibility: hidden; pointer-events: none;
      transition: opacity 0.18s var(--ease), transform 0.18s var(--ease);
      transform: translateX(-50%) translateY(-6px);
    }
    .nav-links > li:hover .nav-dropdown {
      opacity: 1; visibility: visible; pointer-events: auto;
      transform: translateX(-50%) translateY(0);
    }
    .nav-dropdown a {
      display: block; padding: 0.6rem 1.4rem;
      font-family: var(--font-jp); font-size: 0.82rem; color: var(--text-secondary);
      transition: background 0.15s, color 0.15s; white-space: nowrap;
    }
    .nav-dropdown a:hover { background: var(--bg-subtle); color: var(--accent); }
    .nav-dropdown-divider { height: 1px; background: var(--border-light); margin: 0.4rem 0; }
    .nav-dropdown-label {
      padding: 0.5rem 1.4rem 0.2rem;
      font-family: var(--font-en); font-size: 0.6rem; font-weight: 700;
      letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-dim);
    }

    .lang-toggle { display: flex; align-items: center; background: var(--bg-card); border-radius: 20px; padding: 3px; margin-left: 1.4rem; border: 1px solid var(--border); }
    .lang-btn { font-family: var(--font-en); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em; padding: 5px 13px; border-radius: 16px; border: none; cursor: pointer; background: transparent; color: var(--text-dim); transition: all 0.2s; }
    .lang-btn.active { background: var(--accent); color: #fff; }
    .lang-btn:hover:not(.active) { color: var(--text-primary); }
    .nav-cta { font-family: var(--font-jp); font-size: 0.82rem; font-weight: 600; padding: 9px 22px; border-radius: 6px; background: var(--accent); color: #fff; margin-left: 1.2rem; transition: background 0.2s, transform 0.2s; white-space: nowrap; }
    .nav-cta:hover { background: var(--accent-light); transform: translateY(-1px); }

    /* ─── HERO ─── */
    .hero {
      position: relative; min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden; background: #ffffff; padding-top: 68px; padding-bottom: 80px;
    }
    .hero-bg { position: absolute; inset: 0; overflow: hidden; pointer-events: none; }
    /* teamLab-inspired kinetic-typography canvas — drawn on white, behind content */
    .hero-canvas {
      position: absolute; inset: 0; width: 100%; height: 100%; z-index: 1;
      pointer-events: none; opacity: 0; transition: opacity 1.4s ease;
    }
    .hero-canvas.ready { opacity: 1; }
    /* 見出しテキストの可読性確保：本文ブロックの背後だけ柔らかい白グロウを敷く */
    .hero-content::before {
      content: ''; position: absolute; z-index: -1; inset: -10% -8%;
      background: radial-gradient(ellipse 64% 62% at 50% 50%, rgba(255,255,255,0.86) 0%, rgba(255,255,255,0.62) 42%, rgba(255,255,255,0) 74%);
      pointer-events: none;
    }
    .hero-bg-grid {
      position: absolute; inset: 0;
      background-image: linear-gradient(to right, rgba(26,63,191,0.04) 1px, transparent 1px), linear-gradient(to bottom, rgba(26,63,191,0.04) 1px, transparent 1px);
      background-size: 56px 56px;
      mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 20%, transparent 75%);
    }
    .hero-content { position: relative; z-index: 2; text-align: center; padding: 0 2rem; max-width: 840px; }

    .hero-eyebrow { font-family: var(--font-en); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.3em; text-transform: uppercase; color: var(--accent); margin-bottom: 2rem; opacity: 0; transform: translateY(14px); animation: fadeUp 0.8s 0.2s var(--ease) forwards; }

    .hero-title { font-family: var(--font-jp); font-size: clamp(1.7rem, 3.2vw, 2.9rem); font-weight: 700; line-height: 1.5; color: var(--text-primary); margin-bottom: 1.6rem; word-break: keep-all; opacity: 0; transform: translateY(20px); animation: fadeUp 0.8s 0.35s var(--ease) forwards; }
    .hero-title .accent { color: var(--accent); }
    .hero-title-sub { font-family: var(--font-jp); font-size: clamp(0.88rem, 1.4vw, 1.05rem); font-weight: 400; color: var(--text-secondary); line-height: 1.8; margin-bottom: 2.8rem; letter-spacing: 0.04em; opacity: 0; transform: translateY(14px); animation: fadeUp 0.8s 0.5s var(--ease) forwards; }
    .hero-title-sub .accent { color: var(--accent); font-weight: 600; }

    .hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; opacity: 0; transform: translateY(14px); animation: fadeUp 0.8s 0.7s var(--ease) forwards; }
    .btn-primary { font-family: var(--font-jp); font-size: 0.9rem; font-weight: 600; padding: 14px 36px; border-radius: 6px; background: var(--accent); color: #fff; border: none; cursor: pointer; display: inline-block; transition: background 0.2s, transform 0.2s, box-shadow 0.2s; }
    .btn-primary:hover { background: var(--accent-light); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(26,63,191,0.2); }
    .btn-outline { font-family: var(--font-jp); font-size: 0.9rem; font-weight: 500; padding: 14px 36px; border-radius: 6px; background: transparent; color: var(--text-primary); border: 1.5px solid var(--border); cursor: pointer; display: inline-block; transition: border-color 0.2s, color 0.2s, transform 0.2s; }
    .btn-outline:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }


    .hero-scroll { position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%); z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; font-family: var(--font-en); font-size: 0.6rem; font-weight: 500; letter-spacing: 0.22em; text-transform: uppercase; color: var(--text-dim); opacity: 0; animation: fadeUp 1s 1.2s ease forwards; }
    .hero-scroll::after { content: ''; width: 1px; height: 36px; background: linear-gradient(to bottom, var(--accent), transparent); animation: pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{opacity:0.3} 50%{opacity:1} }

    /* ─── MEDIA BAR ─── */
    .media-showcase { padding: 56px 0 48px; border-bottom: 1px solid var(--border); background: var(--bg); }
    .media-label { font-family: var(--font-en); font-size: 0.64rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-dim); white-space: nowrap; }
    .media-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; margin-top: 1.4rem; }
    .media-card { display: flex; flex-direction: column; border: 1px solid var(--border); background: var(--bg); transition: border-color 0.25s; }
    .media-card:hover { border-color: var(--accent); }
    .media-card-photo { position: relative; aspect-ratio: 3 / 2; overflow: hidden; background: var(--bg-subtle); border-bottom: 1px solid var(--border-light); }
    .media-card-photo img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s var(--ease); }
    .media-card:hover .media-card-photo img { transform: scale(1.03); }
    /* 写真ファイル未設置時のフォールバック（media/README.md 参照） */
    .media-card-plate { display: none; position: absolute; inset: 0; align-items: center; justify-content: center; font-family: var(--font-en); font-size: 1.05rem; font-weight: 700; letter-spacing: 0.18em; color: var(--text-dim); }
    .media-card-plate em { font-style: normal; color: var(--accent); margin-left: 0.4em; }
    .media-card.noimg .media-card-photo img { display: none; }
    .media-card.noimg .media-card-plate { display: flex; }
    .media-card-body { padding: 1.1rem 1.3rem 1.3rem; }
    .media-card-date { font-family: var(--font-en); font-size: 0.66rem; font-weight: 600; letter-spacing: 0.14em; color: var(--text-dim); font-variant-numeric: tabular-nums; }
    .media-card-title { font-size: 0.84rem; font-weight: 500; line-height: 1.7; color: var(--text-primary); margin-top: 0.45rem; }
    .media-logos-row { display: flex; align-items: center; gap: 2.5rem; flex-wrap: wrap; margin-top: 2rem; }
    .media-logos-row .media-label { font-size: 0.6rem; }
    .media-logo-item { display: flex; align-items: center; opacity: 0.45; transition: opacity 0.2s; }
    .media-logo-item:hover { opacity: 0.75; }
    @media (max-width: 860px) { .media-cards { grid-template-columns: 1fr; } }

    /* ─── SECTION BASE ─── */
    .section { padding: 100px 0; }
    .section-alt { background: var(--bg-subtle); }
    .container { max-width: 1160px; margin: 0 auto; padding: 0 3rem; }

    .section-label { display: inline-flex; align-items: center; gap: 0.6rem; font-family: var(--font-en); font-size: 0.66rem; font-weight: 700; letter-spacing: 0.25em; text-transform: uppercase; color: var(--accent); margin-bottom: 1.2rem; }
    .section-label::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }
    .section-heading { font-family: var(--font-jp); font-size: clamp(1.4rem, 2.4vw, 2rem); font-weight: 700; line-height: 1.3; color: var(--text-primary); }
    .section-sub { font-size: 0.95rem; color: var(--text-secondary); line-height: 2; margin-top: 1rem; max-width: 560px; }

    /* ─── REVEAL ─── */
    .reveal { opacity: 0; transform: translateY(22px); transition: opacity 0.7s var(--ease), transform 0.7s var(--ease); }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .d1 { transition-delay: 0.1s; }
    .d2 { transition-delay: 0.2s; }
    .d3 { transition-delay: 0.3s; }
    .d4 { transition-delay: 0.4s; }

    /* ─── WHY ZETAX ─── */

    .why-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); }
    .why-card { background: var(--bg); padding: 3rem; transition: background 0.2s; }
    .why-card:hover { background: #fafbff; }
    .why-card-number { font-family: var(--font-en); font-size: 0.68rem; font-weight: 700; letter-spacing: 0.2em; color: var(--accent); margin-bottom: 1.2rem; }
    .why-card-title { font-weight: 700; font-size: 1.05rem; color: var(--text-primary); margin-bottom: 0.8rem; line-height: 1.5; }
    .why-card-desc { font-size: 0.88rem; color: var(--text-secondary); line-height: 2; }
    .why-card-stat { display: flex; align-items: baseline; gap: 0.35rem; margin-top: 1.6rem; }
    .why-card-stat-num { font-family: var(--font-en); font-size: 1.6rem; font-weight: 700; color: var(--accent); letter-spacing: -0.02em; line-height: 1; }
    .why-card-stat-num em { font-style: normal; font-size: 0.6em; }
    .why-card-stat-label { font-size: 0.74rem; color: var(--text-dim); }


    /* ─── HERO COMPARISON (E) ─── */

    /* ─── PROCESS (B) ─── */
    .process-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); margin-top: 4rem; }
    .process-step { background: var(--bg); padding: 2.4rem 2rem; position: relative; }
    .process-step::after { content: '→'; position: absolute; top: 2.4rem; right: -0.8rem; font-size: 0.9rem; color: var(--border); z-index: 1; }
    .process-step:last-child::after { display: none; }
    .process-num { font-family: var(--font-en); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; color: var(--accent); margin-bottom: 0.8rem; }
    .process-timing { font-family: var(--font-jp); font-size: 1.1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.6rem; }
    .process-title { font-size: 0.88rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.6rem; }
    .process-desc { font-size: 0.8rem; color: var(--text-secondary); line-height: 1.9; }
    @media (max-width: 768px) { .process-grid { grid-template-columns: repeat(2, 1fr); } .process-step::after { display: none; } }

    /* ─── TESTIMONIALS (D) ─── */
    .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); margin-top: 4rem; }
    .testimonial-card { background: var(--bg); padding: 2.4rem; }
    .testimonial-quote { font-size: 0.9rem; color: var(--text-primary); line-height: 2; margin-bottom: 1.6rem; position: relative; padding-top: 1.4rem; }
    .testimonial-quote::before { content: '"'; position: absolute; top: 0; left: 0; font-family: Georgia, serif; font-size: 2.4rem; color: var(--accent); line-height: 1; opacity: 0.4; }
    .testimonial-source { border-top: 1px solid var(--border-light); padding-top: 1rem; }
    .testimonial-company { font-size: 0.75rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.2rem; }
    .testimonial-person { font-size: 0.72rem; color: var(--text-dim); }
    @media (max-width: 768px) { .testimonials-grid { grid-template-columns: 1fr; } }

    /* ─── SECURITY HIGHLIGHT ─── */
    .security-highlight { background: var(--text-primary); border-radius: 0; padding: 64px 0; margin-top: 0; }
    .security-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
    .security-label { font-family: var(--font-en); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.25em; text-transform: uppercase; color: #7b96ff; margin-bottom: 1.2rem; display: flex; align-items: center; gap: 0.5rem; }
    .security-label::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: #7b96ff; }
    .security-heading { font-family: var(--font-jp); font-size: clamp(1.3rem, 2.2vw, 1.8rem); font-weight: 700; color: #fff; line-height: 1.35; margin-bottom: 1.2rem; }
    .security-desc { font-size: 0.9rem; color: rgba(255,255,255,0.55); line-height: 2; }
    .security-items { display: flex; flex-direction: column; gap: 1px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08); }
    .security-item { background: rgba(255,255,255,0.02); padding: 1.4rem 1.8rem; transition: background 0.2s; }
    .security-item:hover { background: rgba(255,255,255,0.05); }
    .security-item-title { font-size: 0.88rem; font-weight: 600; color: #fff; margin-bottom: 0.3rem; }
    .security-item-desc { font-size: 0.78rem; color: rgba(255,255,255,0.45); line-height: 1.7; }
    @media (max-width: 768px) { .security-inner { grid-template-columns: 1fr; gap: 2.5rem; } }

    /* ─── SERVICES ─── */
    .services-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; margin-top: 4rem; background: var(--border); border: 1px solid var(--border); }
    .service-card { background: var(--bg); padding: 3rem; position: relative; display: block; transition: background 0.2s; }
    .service-card:hover { background: #fafbff; }
    .service-num { font-family: var(--font-en); font-size: 0.66rem; font-weight: 700; letter-spacing: 0.2em; margin-bottom: 1.6rem; color: var(--accent); }
    .service-title { font-size: 1.05rem; font-weight: 700; line-height: 1.45; margin-bottom: 1rem; color: var(--text-primary); }
    .service-desc { font-size: 0.88rem; line-height: 2; margin-bottom: 2rem; color: var(--text-secondary); }
    .service-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; }
    .service-tag { font-family: var(--font-jp); font-size: 0.7rem; padding: 4px 12px; border-radius: 2px; border: 1px solid var(--border); color: var(--text-secondary); }
    .service-link { font-family: var(--font-en); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.06em; color: var(--accent); }

    /* ─── PRODUCTS ─── */
    .product-featured { display: grid; grid-template-columns: 1fr 1fr; gap: 0; margin-top: 4rem; border: 1px solid var(--border); border-radius: 10px; overflow: hidden; background: var(--bg); transition: box-shadow 0.3s; }
    .product-featured:hover { box-shadow: 0 12px 40px rgba(0,0,0,0.06); }
    .product-featured-text { padding: 3rem; display: flex; flex-direction: column; justify-content: center; }
    .product-featured-badge { display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-en); font-size: 0.62rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #fff; background: var(--accent); padding: 5px 14px; border-radius: 4px; margin-bottom: 1.2rem; width: fit-content; }
    .product-featured-name { font-family: var(--font-en); font-size: 1.6rem; font-weight: 800; color: var(--text-primary); margin-bottom: 0.3rem; }
    .product-featured-sub { font-family: var(--font-jp); font-size: 0.88rem; font-weight: 600; color: var(--accent); margin-bottom: 1rem; }
    .product-featured-desc { font-size: 0.88rem; line-height: 2; color: var(--text-secondary); margin-bottom: 1.6rem; }
    .product-featured-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.6rem; }
    .product-featured-tags span { font-size: 0.68rem; font-weight: 600; padding: 4px 10px; border-radius: 3px; background: var(--accent-pale, #e8edf8); color: var(--accent); }
    .product-featured-cta { display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-jp); font-size: 0.88rem; font-weight: 700; color: #fff; background: var(--accent); padding: 12px 28px; border-radius: 6px; transition: background 0.2s, transform 0.2s; width: fit-content; }
    .product-featured-cta:hover { background: #4a6fc4; transform: translateY(-2px); }
    .product-featured-visual { background: linear-gradient(160deg, #0f1b3d, #1e3a7b); display: flex; align-items: center; justify-content: center; padding: 2.5rem; min-height: 320px; position: relative; overflow: hidden; }
    .product-featured-visual::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 30% 50%, rgba(74,111,196,0.2) 0%, transparent 70%); pointer-events: none; }
    .pf-mockup { position: relative; z-index: 1; width: 100%; max-width: 360px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 1rem; backdrop-filter: blur(8px); }
    .pf-mockup-bar { display: flex; align-items: center; margin-bottom: 0.8rem; padding-bottom: 0.6rem; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .pfm-title { font-family: var(--font-en); font-size: 0.6rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.4); }
    .pf-mockup-row { display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 0.7rem; border-radius: 6px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); margin-bottom: 0.35rem; font-size: 0.72rem; }
    .pf-mockup-row:last-child { margin-bottom: 0; }
    .pfm-label { color: rgba(255,255,255,0.45); }
    .pfm-val { font-family: var(--font-en); font-weight: 700; color: #fff; }
    .pfm-badge { font-size: 0.56rem; font-weight: 700; padding: 2px 7px; border-radius: 3px; background: rgba(22,163,74,0.2); color: #4ade80; }
    @media (max-width: 900px) { .product-featured { grid-template-columns: 1fr; } .product-featured-visual { min-height: 240px; } }
    .products-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); margin-top: 1.5rem; }
    .product-card { background: var(--bg); padding: 2.8rem; transition: background 0.2s; }
    .product-card:hover { background: #fafbff; }
    .product-type { font-family: var(--font-en); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 1.4rem; color: var(--accent); }
    .product-name { font-family: var(--font-jp); font-size: 1.1rem; font-weight: 700; line-height: 1.4; margin-bottom: 0.5rem; color: var(--text-primary); }
    .product-name-en { font-family: var(--font-en); font-size: 0.72rem; letter-spacing: 0.06em; margin-bottom: 1.2rem; color: var(--text-dim); }
    .product-desc { font-size: 0.88rem; line-height: 2; margin-bottom: 1.8rem; color: var(--text-secondary); }
    .product-achievement { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-jp); font-size: 0.75rem; font-weight: 600; padding: 6px 14px; border-radius: 2px; background: var(--accent-pale); color: var(--accent); }
    .product-achievement::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
    .product-hw-label { font-size: 0.82rem; color: var(--text-dim); font-style: italic; margin-top: 1rem; }
    .product-creators { font-family: var(--font-jp); font-size: 0.7rem; color: rgba(255,255,255,0.3); margin-top: 1rem; letter-spacing: 0.04em; }
    @media (max-width: 1024px) { .products-grid { grid-template-columns: 1fr; } }

    /* ─── CASES ─── */
    .cases-header { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: end; margin-bottom: 4rem; }
    .cases-list { border-top: 1px solid var(--border); }
    .case-row { display: grid; grid-template-columns: 200px 1fr; gap: 0; border-bottom: 1px solid var(--border); }
    .case-industry { padding: 2.8rem 2rem 2.8rem 0; border-right: 1px solid var(--border); display: flex; flex-direction: column; justify-content: flex-start; }
    .case-industry-label { font-family: var(--font-jp); font-size: 1rem; font-weight: 700; color: var(--text-primary); }
    .case-industry-en { font-family: var(--font-en); font-size: 0.68rem; font-weight: 500; letter-spacing: 0.08em; color: var(--text-dim); margin-top: 0.3rem; }
    .case-projects { padding: 2.8rem 0 2.8rem 2.8rem; display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem; }
    .case-project { background: var(--bg-card); border: 1px solid var(--border-light); border-radius: 3px; padding: 1.2rem 1.4rem; transition: border-color 0.2s, background 0.2s; }
    .case-project:hover { border-color: rgba(26,63,191,0.2); background: #fafbff; }
    .case-project-name { font-size: 0.86rem; font-weight: 600; color: var(--text-primary); line-height: 1.5; }
    @media (max-width: 768px) {
      .case-row { grid-template-columns: 1fr; }
      .case-industry { padding: 1.5rem 0 0.5rem; border-right: none; border-bottom: 1px solid var(--border-light); }
      .case-projects { padding: 1.5rem 0; grid-template-columns: 1fr 1fr; }
    }

    /* ─── COMPANY ─── */
    .company-tabs { display: flex; border-bottom: 1px solid var(--border); margin-bottom: 3rem; }
    .company-tab { font-family: var(--font-en); font-size: 0.8rem; font-weight: 600; letter-spacing: 0.06em; padding: 0.9rem 1.8rem; border: none; border-bottom: 2px solid transparent; background: transparent; color: var(--text-dim); cursor: pointer; margin-bottom: -1px; transition: color 0.2s, border-color 0.2s; }
    .company-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
    .company-tab:hover:not(.active) { color: var(--text-primary); }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    .company-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    .company-table tr { border-bottom: 1px solid var(--border-light); }
    .company-table th { padding: 1.2rem 2rem 1.2rem 0; text-align: left; font-weight: 600; color: var(--text-primary); font-size: 0.82rem; white-space: nowrap; width: 160px; vertical-align: top; }
    .company-table td { padding: 1.2rem 1.5rem; color: var(--text-secondary); line-height: 1.9; }

    .founders-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); }
    .founder-card { background: var(--bg); padding: 3rem; display: flex; gap: 2.4rem; align-items: flex-start; }
    .founder-photo { width: 140px; height: 172px; object-fit: cover; object-position: top; flex-shrink: 0; border: 1px solid var(--border); }
    .founder-info { flex: 1; }
    .founder-name { font-family: var(--font-jp); font-size: 1.3rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.3rem; }
    .founder-role { font-family: var(--font-en); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em; color: var(--accent); margin-bottom: 0.4rem; }
    .founder-affil { font-size: 0.76rem; color: var(--text-dim); margin-bottom: 1rem; }
    .founder-bio { font-size: 0.86rem; color: var(--text-secondary); line-height: 2; }
    @media (max-width: 1024px) {
      .founders-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 640px) {
      .founder-card { flex-direction: column; gap: 1.5rem; }
      .founder-photo { width: 100%; height: 220px; }
    }

    /* ─── NEWS ─── */
    .news-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 0; }
    .btn-sm { font-family: var(--font-en); font-size: 0.76rem; font-weight: 500; padding: 8px 18px; border-radius: 4px; border: 1px solid var(--border); color: var(--text-secondary); background: transparent; transition: border-color 0.2s, color 0.2s; display: inline-block; }
    .btn-sm:hover { border-color: var(--accent); color: var(--accent); }
    .news-list { border-top: 1px solid var(--border); margin-top: 2rem; }
    .news-item { display: flex; align-items: center; gap: 2rem; padding: 1.3rem 0; border-bottom: 1px solid var(--border-light); transition: opacity 0.2s; }
    .news-item:hover { opacity: 0.7; }
    .news-date { font-family: var(--font-en); font-size: 0.76rem; color: var(--text-dim); white-space: nowrap; min-width: 88px; }
    .news-cat { font-family: var(--font-jp); font-size: 0.68rem; font-weight: 600; padding: 3px 10px; border-radius: 2px; background: var(--accent-pale); color: var(--accent); white-space: nowrap; }
    .news-title { font-size: 0.92rem; color: var(--text-primary); flex: 1; line-height: 1.6; }

    /* ─── CONTACT ─── */
    .contact-wrap { display: grid; grid-template-columns: 1fr 1.5fr; gap: 5rem; align-items: start; }
    .contact-title { font-family: var(--font-jp); font-size: 1.4rem; font-weight: 700; line-height: 1.5; margin-bottom: 1.2rem; }
    .contact-desc { font-size: 0.92rem; color: var(--text-secondary); line-height: 2; margin-bottom: 2rem; }
    .contact-meta { display: flex; flex-direction: column; gap: 0.9rem; }
    .contact-meta-item { display: flex; align-items: flex-start; gap: 0.7rem; }
    .contact-meta-icon { width: 16px; height: 16px; flex-shrink: 0; margin-top: 0.2rem; color: var(--accent); }
    .contact-meta-text { font-size: 0.86rem; color: var(--text-secondary); line-height: 1.7; }

    .contact-form { background: var(--bg); border: 1px solid var(--border); border-radius: 4px; padding: 2.4rem; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.45rem; margin-bottom: 1.1rem; }
    .form-label { font-family: var(--font-en); font-size: 0.73rem; font-weight: 600; letter-spacing: 0.04em; color: var(--text-primary); }
    .form-label .req { color: var(--accent); margin-left: 3px; }
    .form-input, .form-select, .form-textarea { font-family: var(--font-jp); font-size: 0.9rem; color: var(--text-primary); background: var(--bg-card); border: 1px solid var(--border); border-radius: 4px; padding: 11px 14px; outline: none; width: 100%; transition: border-color 0.2s, box-shadow 0.2s; }
    .form-input:focus, .form-select:focus, .form-textarea:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(26,63,191,0.07); }
    .form-textarea { resize: vertical; min-height: 110px; }
    .form-submit { width: 100%; padding: 14px; background: var(--accent); color: #fff; border: none; border-radius: 4px; font-family: var(--font-jp); font-size: 0.92rem; font-weight: 600; letter-spacing: 0.06em; cursor: pointer; margin-top: 0.4rem; transition: background 0.2s, transform 0.2s; }
    .form-submit:hover { background: var(--accent-light); transform: translateY(-1px); }
    .form-success { display: none; text-align: center; padding: 2.5rem 1rem; }
    .form-success p { color: var(--accent); font-size: 0.95rem; }

    /* ─── FOOTER ─── */
    .footer { background: var(--text-primary); padding: 64px 0 40px; }
    .footer-grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr; gap: 3rem; margin-bottom: 3rem; }
    .footer-logo { font-family: var(--font-en); font-size: 1.15rem; font-weight: 700; letter-spacing: 0.1em; color: #fff; margin-bottom: 0.9rem; }
    .footer-logo span { color: #7b96ff; }
    .footer-about { font-size: 0.82rem; color: rgba(255,255,255,0.38); line-height: 1.9; }
    .footer-col-label { font-family: var(--font-en); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.28); margin-bottom: 1.2rem; }
    .footer-links { list-style: none; display: flex; flex-direction: column; gap: 0.7rem; }
    .footer-links a { font-size: 0.84rem; color: rgba(255,255,255,0.52); transition: color 0.2s; }
    .footer-links a:hover { color: #fff; }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,0.07); padding-top: 2rem; display: flex; justify-content: space-between; align-items: center; }
    .footer-copy { font-family: var(--font-en); font-size: 0.74rem; color: rgba(255,255,255,0.25); }
    .footer-legal { display: flex; gap: 1.5rem; }
    .footer-legal a { font-family: var(--font-en); font-size: 0.74rem; color: rgba(255,255,255,0.3); transition: color 0.2s; }
    .footer-legal a:hover { color: rgba(255,255,255,0.65); }

    /* ─── CURSOR ─── */
    * { cursor: none !important; }
    .cursor-dot {
      position: fixed; width: 8px; height: 8px; border-radius: 50%;
      background: var(--accent); pointer-events: none; z-index: 99999;
      transform: translate(-50%,-50%); transition: transform 0.08s, background 0.2s, width 0.2s, height 0.2s;
      will-change: left, top;
    }
    .cursor-ring {
      position: fixed; width: 38px; height: 38px; border-radius: 50%;
      border: 1.5px solid rgba(26,63,191,0.35); pointer-events: none; z-index: 99998;
      transform: translate(-50%,-50%); transition: width 0.3s var(--ease), height 0.3s var(--ease), border-color 0.3s, opacity 0.3s;
      will-change: left, top;
    }
    body:has(a:hover, button:hover) .cursor-dot { width: 12px; height: 12px; background: var(--accent-light); }
    body:has(a:hover, button:hover) .cursor-ring { width: 56px; height: 56px; border-color: rgba(26,63,191,0.2); }
    @media (hover: none) { * { cursor: auto !important; } .cursor-dot, .cursor-ring { display: none; } }

    /* ─── SCROLL PROGRESS ─── */
    .scroll-progress {
      position: fixed; top: 0; left: 0; height: 2px; width: 0%;
      background: linear-gradient(90deg, var(--accent), #7b96ff);
      z-index: 1002; transition: width 0.05s linear; pointer-events: none;
    }

    /* ─── GRAIN / NOISE ─── */
    body::after {
      content: '';
      position: fixed; inset: 0; z-index: 9990; pointer-events: none;
      opacity: 0.032;
      background-image: url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' width='180' height='180'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.72' numOctaves='4' stitchTiles='stitch'/><feColorMatrix type='saturate' values='0'/></filter><rect width='180' height='180' filter='url(%23n)'/></svg>");
      background-size: 180px 180px;
    }

    /* ─── FLOAT CTA ─── */
    .float-cta {
      position: fixed; bottom: 2.4rem; right: 2.4rem; z-index: 800;
      display: flex; align-items: center; gap: 0.6rem;
      background: var(--accent); color: #fff;
      font-family: var(--font-jp); font-size: 0.82rem; font-weight: 700;
      padding: 13px 22px; border-radius: 50px;
      box-shadow: 0 8px 30px rgba(26,63,191,0.35);
      opacity: 0; transform: translateY(16px) scale(0.95); pointer-events: none;
      transition: opacity 0.4s var(--ease), transform 0.4s var(--ease), background 0.2s, box-shadow 0.2s;
    }
    .float-cta.visible { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }
    .float-cta:hover { background: var(--accent-light); box-shadow: 0 12px 36px rgba(26,63,191,0.45); transform: translateY(-2px) scale(1); }
    .float-cta-dot { width: 7px; height: 7px; border-radius: 50%; background: rgba(255,255,255,0.6); animation: pulse 2s ease-in-out infinite; }
    @media (max-width: 768px) { .float-cta { bottom: 1.4rem; right: 1.4rem; font-size: 0.76rem; padding: 11px 18px; } }

    /* ─── 3D TILT CARDS ─── */
    .tilt-card { transition: transform 0.2s var(--ease), box-shadow 0.2s var(--ease); will-change: transform; }
    .tilt-card:hover { box-shadow: 0 20px 60px rgba(26,63,191,0.1); }


    /* ─── PROCESS SVG LINE ─── */
    .process-connector { position: absolute; top: 50%; left: 0; right: 0; height: 2px; pointer-events: none; overflow: visible; }
    .process-connector-path { stroke-dasharray: 800; stroke-dashoffset: 800; transition: stroke-dashoffset 1.4s var(--ease); }
    .process-grid { position: relative; }
    .process-step { z-index: 1; }
    .process-grid.visible .process-connector-path { stroke-dashoffset: 0; }

    /* ─── FOOTER ZETAX WATERMARK ─── */
    .footer-watermark {
      position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
      font-family: var(--font-en); font-size: clamp(5rem, 18vw, 16rem);
      font-weight: 900; letter-spacing: 0.04em; text-transform: uppercase;
      color: transparent; -webkit-text-stroke: 1px rgba(255,255,255,0.04);
      white-space: nowrap; pointer-events: none; user-select: none;
      line-height: 0.85; bottom: -0.1em;
    }
    .footer { position: relative; overflow: hidden; }

    /* ─── G: SECTION DECO TEXT ─── */
    .section-deco-wrap { position: relative; overflow: visible; }
    .section-deco-text {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
      font-family: var(--font-en); font-size: clamp(5rem, 14vw, 12rem);
      font-weight: 900; letter-spacing: 0.06em; text-transform: uppercase;
      color: transparent; -webkit-text-stroke: 1px rgba(26,63,191,0.06);
      white-space: nowrap; pointer-events: none; user-select: none; z-index: 0;
      line-height: 1;
    }

    /* ─── C: SERVICE CARD DECO NUMBER ─── */
    .service-card { overflow: hidden; }
    .service-card-deco {
      position: absolute; top: -0.15em; right: -0.05em;
      font-family: var(--font-en); font-size: clamp(5rem, 11vw, 10rem);
      font-weight: 900; line-height: 1; pointer-events: none; user-select: none;
      transition: transform 0.5s var(--ease), opacity 0.5s;
    }
    .service-card-deco { color: rgba(26,63,191,0.05); }
    .service-card:hover .service-card-deco { transform: scale(1.1) translateY(-6px); }

    /* ─── D: CASES HORIZONTAL SCROLL ─── */
    .cases-scroll-outer {
      overflow-x: auto; overflow-y: hidden; cursor: grab; user-select: none;
      scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;
      padding-bottom: 1.2rem; margin-top: 3rem;
    }
    .cases-scroll-outer:active { cursor: grabbing; }
    .cases-scroll-outer::-webkit-scrollbar { height: 3px; }
    .cases-scroll-outer::-webkit-scrollbar-track { background: var(--border-light); }
    .cases-scroll-outer::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 2px; }
    .cases-scroll-wrap {
      display: flex; gap: 1px; width: max-content;
      background: var(--border); border: 1px solid var(--border);
    }
    .cases-card {
      background: var(--bg); width: 260px; flex-shrink: 0; padding: 2.2rem 1.8rem;
      scroll-snap-align: start; transition: background 0.2s;
    }
    .cases-card:hover { background: #fafbff; }
    .cases-card-industry { font-family: var(--font-jp); font-size: 1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.2rem; }
    .cases-card-industry-en { font-family: var(--font-en); font-size: 0.62rem; letter-spacing: 0.08em; color: var(--text-dim); margin-bottom: 1.2rem; }
    .cases-card-items { list-style: none; display: flex; flex-direction: column; gap: 0.55rem; }
    .cases-card-items li { font-size: 0.8rem; color: var(--text-secondary); line-height: 1.5; padding-left: 1rem; position: relative; }
    .cases-card-items li::before { content: '—'; position: absolute; left: 0; color: var(--accent); font-size: 0.68rem; }
    .cases-scroll-hint { font-family: var(--font-en); font-size: 0.66rem; letter-spacing: 0.14em; color: var(--text-dim); text-transform: uppercase; margin-top: 1rem; display: flex; align-items: center; gap: 0.5rem; }
    .cases-scroll-hint::after { content: ''; flex: 1; height: 1px; background: var(--border); }

    /* ─── E: SECURITY MATRIX CANVAS ─── */
    .security-highlight { position: relative; overflow: hidden; }
    #sec-canvas {
      position: absolute; inset: 0; width: 100%; height: 100%;
      pointer-events: none; opacity: 0.14; z-index: 0;
    }
    .security-inner { position: relative; z-index: 1; }

    /* ─── F: CONTACT GRADIENT MESH ─── */
    .contact-section-dark {
      background: var(--text-primary);
      position: relative; overflow: hidden;
    }
    .contact-mesh {
      position: absolute; inset: 0; pointer-events: none; z-index: 0;
      background:
        radial-gradient(ellipse 60% 80% at 10% 50%, rgba(26,63,191,0.28) 0%, transparent 62%),
