            <thead>
              <tr>
                <th data-ja="項目" data-en="Item">項目</th>
                <th data-ja="従来の開発" data-en="Traditional Development">従来の開発</th>
                <th class="zetax-col" data-ja="ZetaX FDE" data-en="ZetaX FDE">ZetaX FDE</th>
              </tr>
