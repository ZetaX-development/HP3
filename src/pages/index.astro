          <span class="news-text" data-ja="エンジニア・リサーチャーを積極採用中です。ご興味のある方はContactよりお問い合わせください。"
            data-en="Actively recruiting engineers & researchers. If interested, please reach out via Contact.">エンジニア・リサーチャーを積極採用中です。ご興味のある方はContactよりお問い合わせください。</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section contact" id="contact">
    <div class="section-inner">
      <div class="reveal">
        <h2 class="contact-headline">Be the Pioneer.</h2>
        <p class="contact-sub" data-ja="共に先駆者になりましょう。お気軽にお問い合わせください。"
          data-en="Let's be pioneers together. Feel free to get in touch.">共に先駆者になりましょう。お気軽にお問い合わせください。</p>
      </div>
      <form class="contact-form reveal reveal-delay-1" id="contactForm" onsubmit="submitForm(event)">
        <div class="form-row">
          <div class="form-group">
            <label for="name" data-ja="お名前" data-en="Name">お名前</label>
            <input type="text" id="name" name="name" data-ja-placeholder="山田 太郎" data-en-placeholder="John Doe" placeholder="山田 太郎" required>
          </div>
          <div class="form-group">
            <label for="company-name" data-ja="会社名" data-en="Company">会社名</label>
            <input type="text" id="company-name" name="company" data-ja-placeholder="株式会社〇〇" data-en-placeholder="Company Inc."
              placeholder="株式会社〇〇">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="email" data-ja="メールアドレス" data-en="Email">メールアドレス</label>
            <input type="email" id="email" name="email" placeholder="you@example.com" required>
          </div>
          <div class="form-group">
            <label for="interest" data-ja="ご関心のある領域" data-en="Area of Interest">ご関心のある領域</label>
            <select id="interest" name="interest">
              <option value="" disabled selected data-ja="選択してください" data-en="Please select">選択してください</option>
              <option value="AI活用/DXソリューション" data-ja="AI活用/DXソリューション" data-en="AI &amp; DX Solutions">AI活用/DXソリューション</option>
              <option value="製造業特化 異常検知システム" data-ja="製造業特化 異常検知システム" data-en="Manufacturing-Focused Anomaly Detection">製造業特化 異常検知システム</option>
              <option value="その他" data-ja="その他" data-en="Other">その他</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label for="message" data-ja="お問い合わせ内容" data-en="Message">お問い合わせ内容</label>
          <textarea id="message" name="message" data-ja-placeholder="お気軽にご記入ください" data-en-placeholder="Feel free to write here"
            placeholder="お気軽にご記入ください"></textarea>
        </div>
        <button class="cta-btn" type="submit" id="contact-submit-btn">
          Contact Us
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </button>
      </form>

    </div>
  </section>

  <!-- MOBILE FLOATING CTA -->
  <div class="mobile-cta-bar">
    <a href="#contact" class="mobile-cta-btn" data-ja="20分の無料相談を予約" data-en="Book a 20-min consultation">20分の無料相談を予約</a>
  </div>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <p class="footer-copy">&copy; 2026 ZetaX Inc. All Rights Reserved.</p>

    </div>
  </footer>

  <script is:inline>
    // NAV SCROLL
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => { nav.classList.toggle('scrolled', window.scrollY > 50); });

    // REVEAL
    const reveals = document.querySelectorAll('.reveal');
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
    reveals.forEach(el => revealObs.observe(el));

    // SERVICE SLIDE-IN ANIMATION
    const serviceSlideEls = document.querySelectorAll('.service-block .service-text, .service-block .service-visual');
    const serviceObs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('slide-visible'); });
    }, { threshold: 0.12, rootMargin: '0px 0px -30px 0px' });
    serviceSlideEls.forEach(el => serviceObs.observe(el));

    // TABS
    document.querySelectorAll('.company-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.company-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
      });
    });

    // HERO CANVAS
    (function () {
      const canvas = document.getElementById('heroCanvas');
      const ctx = canvas.getContext('2d');
      let w, h, particles = [], mouse = { x: 0, y: 0 };
      function resize() { w = canvas.width = canvas.offsetWidth; h = canvas.height = canvas.offsetHeight; }
      resize(); window.addEventListener('resize', resize);
      canvas.addEventListener('mousemove', (e) => {
        const r = canvas.getBoundingClientRect(); mouse.x = e.clientX - r.left; mouse.y = e.clientY - r.top;
      });
      class P {
        constructor() {
          this.x = Math.random() * w; this.y = Math.random() * h;
          this.vx = (Math.random() - 0.5) * 0.5; this.vy = (Math.random() - 0.5) * 0.5;
          this.r = Math.random() * 1.5 + 0.5;
        }
        update() {
          this.x += this.vx; this.y += this.vy;
          if (this.x < 0 || this.x > w) this.vx *= -1; if (this.y < 0 || this.y > h) this.vy *= -1;
          const dx = mouse.x - this.x, dy = mouse.y - this.y, d = Math.sqrt(dx * dx + dy * dy);
          if (d < 200) { this.x -= dx * 0.005; this.y -= dy * 0.005; }
        }
        draw() {
          ctx.beginPath(); ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(96,165,250,0.5)'; ctx.fill();
        }
      }
      for (let i = 0; i < 120; i++) particles.push(new P());
      function animate() {
        ctx.clearRect(0, 0, w, h);
        particles.forEach(p => { p.update(); p.draw(); });
        for (let i = 0; i < particles.length; i++) for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x, dy = particles[i].y - particles[j].y;
          const d = Math.sqrt(dx * dx + dy * dy);
          if (d < 150) {
            ctx.beginPath(); ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = `rgba(59,130,246,${0.12 * (1 - d / 150)})`; ctx.lineWidth = 0.5; ctx.stroke();
          }
        }
        requestAnimationFrame(animate);
      }
      animate();
    })();

    // (Service visuals are now CSS/SVG-based, no canvas needed)

    // SMOOTH SCROLL (offset for fixed nav)
    document.querySelectorAll('.nav-links a').forEach(a => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const t = document.querySelector(a.getAttribute('href'));
        if (!t) return;
        const navEl = document.querySelector('.nav');
        const offset = (navEl ? navEl.offsetHeight : 80) + 16;
        const top = t.getBoundingClientRect().top + window.pageYOffset - offset;
        window.scrollTo({ top, behavior: 'smooth' });
      });
    });

    // LANGUAGE SWITCH
    function switchLang(lang) {
      document.documentElement.dataset.lang = lang;
      document.documentElement.lang = lang;
      // Toggle active button
      document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.lang === lang);
      });
      // Switch text content for elements with data-ja / data-en
      document.querySelectorAll('[data-ja][data-en]').forEach(el => {
        const text = el.getAttribute('data-' + lang);
        if (text !== null) el.innerHTML = text;
      });
      // Switch placeholders
      document.querySelectorAll('[data-' + lang + '-placeholder]').forEach(el => {
        el.placeholder = el.getAttribute('data-' + lang + '-placeholder');
      });
      // Switch option text
      document.querySelectorAll('select option[data-ja][data-en]').forEach(opt => {
        opt.textContent = opt.getAttribute('data-' + lang);
      });
      // Store preference
      try { localStorage.setItem('zetax-lang', lang); } catch (e) { }
    }
    // Restore preference
    (function () {
      try {
        var saved = localStorage.getItem('zetax-lang');
        if (saved && saved !== 'ja') switchLang(saved);
      } catch (e) { }
    })();

    // CONTACT FORM - FORMSPREE
    async function submitForm(event) {
      event.preventDefault();
      const form = event.target;
      const btn = document.getElementById('contact-submit-btn');
      const originalBtnText = btn.innerHTML;
      const lang = document.documentElement.dataset.lang || 'ja';

      // 1. バリデーション (HTML5のrequired属性でもチェックされますが、念のため)
      const name = form.name.value;
      const email = form.email.value;
      if (!name || !email) {
        alert(lang === 'en' ? 'Please fill in your name and email.' : 'お名前とメールアドレスをご記入ください。');
        return;
      }

      // 2. 送信中表示
      btn.disabled = true;
      btn.innerHTML = lang === 'en' ? 'Sending...' : '送信中...';

      // 3. Formspreeへ送信
      // 【重要】以下のIDをご自身のFormspreeフォームIDに書き換えてください
      // 例: "https://formspree.io/f/mqkrvvgz"
      const FORMSPREE_ENDPOINT = "https://formspree.io/f/mreapyjk";

      try {
        const response = await fetch(FORMSPREE_ENDPOINT, {
          method: 'POST',
          body: new FormData(form),
          headers: {
            'Accept': 'application/json'
          }
        });

        if (response.ok) {
          alert(lang === 'en' ? 'Thank you! Your message has been sent.' : 'お問い合わせありがとうございます。送信が完了しました。');
          form.reset();
        } else {
          const data = await response.json();
          if (Object.hasOwn(data, 'errors')) {
            alert(lang === 'en' ? 'Error: ' + data.errors.map(error => error.message).join(", ") : '送信エラー: ' + data.errors.map(error => error.message).join(", "));
          } else {
            alert(lang === 'en' ? 'Oops! There was a problem submitting your form.' : '送信中にエラーが発生しました。');
          }
        }
      } catch (error) {
        alert(lang === 'en' ? 'Oops! There was a problem submitting your form.' : '送信中にエラーが発生しました。');
        console.error(error);
      } finally {
        // ボタンを元に戻す
        btn.disabled = false;
        btn.innerHTML = originalBtnText;
      }
    }
  </script>
</body>

</html>
