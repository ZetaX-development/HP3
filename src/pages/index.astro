      .reality-quote-text { font-size: 1rem; line-height: 1.7; }
      .reality-question { font-size: 1.15rem; margin-bottom: 1.5rem; }
      .challenge-grid { grid-template-columns: 1fr !important; gap: 1rem; }
      .challenge-card { padding: 1.5rem 1.25rem; }
      .challenge-title { font-size: 1rem; }
      .challenge-desc { font-size: 0.88rem; }

      /* FDE */
      .fde-intro { margin-top: 2rem; }
      .fde-desc { font-size: 0.92rem; }
      .compare-table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; margin: 0 -1.25rem; padding: 0 1.25rem; }
      .compare-table { min-width: 560px; font-size: 0.82rem; }
      .compare-table th, .compare-table td { padding: 0.75rem 0.6rem; }

      /* Solutions — anomaly detection (manufacturing) first on mobile */
      .solutions-grid { grid-template-columns: 1fr !important; gap: 1.25rem; }
      .solution-card { padding: 2rem 1.5rem; }
      .solutions-grid .solution-secondary { order: -1; }

      /* Company */
      .company-tabs { flex-wrap: wrap; gap: 0.5rem; }
      .company-tab { font-size: 0.78rem; padding: 0.55rem 0.9rem; }
      .company-table th, .company-table td { padding: 0.85rem 0.75rem; font-size: 0.85rem; }
      .company-table th { width: 30%; }
      .ceo-grid { grid-template-columns: 1fr !important; max-width: 320px; margin-left: auto; margin-right: auto; }
      .team-grid { grid-template-columns: 1fr 1fr !important; gap: 1rem; }
      .team-card { padding: 1.25rem 1rem; }
      .team-card h4 { font-size: 0.9rem; }
      .team-bio { font-size: 0.78rem; }

      /* News */
      .news-item { flex-direction: column; align-items: flex-start; gap: 0.5rem; padding: 1.25rem 0; }
      .news-date { min-width: 0; font-size: 0.75rem; }
      .news-text { font-size: 0.88rem; }
      .news-link { margin-left: 0; display: inline-flex; margin-top: 0.35rem; }

      /* Contact */
      .contact-headline { font-size: clamp(1.8rem, 7vw, 2.6rem); }
      .contact-form { padding: 1.5rem; }
      .form-row { grid-template-columns: 1fr !important; gap: 1.25rem; }

      /* Footer */
      .footer-inner { flex-direction: column; gap: 1rem; text-align: center; padding: 0 1.25rem; }
      .footer-links { gap: 1.25rem; flex-wrap: wrap; justify-content: center; }
    }

    @media (max-width: 600px) {
      .team-grid { grid-template-columns: 1fr !important; max-width: 320px; margin-left: auto; margin-right: auto; }
      .hero-pills { gap: 0.4rem; }
      .compare-table { min-width: 480px; }
    }

    /* MOBILE FLOATING CONTACT BAR */
    .mobile-cta-bar { display: none; position: fixed; bottom: 0; left: 0; right: 0; z-index: 99; padding: 0.75rem 1rem calc(0.75rem + env(safe-area-inset-bottom, 0)); background: rgba(255,255,255,0.97); backdrop-filter: blur(12px); border-top: 1px solid rgba(0,0,0,0.08); box-shadow: 0 -4px 24px rgba(0,0,0,0.06); }
    .mobile-cta-btn { display: flex; align-items: center; justify-content: center; gap: 0.5rem; width: 100%; background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 50%, #3b82f6 100%); color: #ffffff; font-size: 0.95rem; font-weight: 700; letter-spacing: 0.04em; padding: 0.95rem 1.25rem; border-radius: 12px; box-shadow: 0 8px 24px rgba(37,99,235,0.3); }
    .mobile-cta-btn::after { content: "→"; font-size: 1.1em; }
    @media (max-width: 900px) {
      body { padding-bottom: 5rem; }
      .mobile-cta-bar { display: block; }
    }

  </style>
</head>

