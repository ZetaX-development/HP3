      .news-item { flex-wrap: wrap; gap: 0.6rem; }
      .news-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
      .media-bar .container { flex-direction: column; align-items: flex-start; gap: 1rem; }
    }
  </style>
</head>

