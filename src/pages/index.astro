          zxIntro.classList.add("zxi-done");                    // 幕が明ける
          document.documentElement.classList.remove("zx-hold"); // ヒーローの fadeUp 再生開始
        }, 1150);
        setTimeout(() => zxIntro.remove(), 1700);
      });
      try { sessionStorage.setItem("zxIntroSeen", "1"); } catch (e) { /* noop */ }
