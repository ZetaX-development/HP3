    /* ─── AURORA: blob animations ─── */
    .hero-bg-blob-1 { animation: blobFloat1 14s ease-in-out infinite alternate; }
    .hero-bg-blob-2 { animation: blobFloat2 20s ease-in-out infinite alternate; }
    @keyframes blobFloat1 { 0%{transform:translate(0,0) scale(1)} 100%{transform:translate(-6%,10%) scale(1.12)} }
    @keyframes blobFloat2 { 0%{transform:translate(0,0) scale(1.05)} 100%{transform:translate(8%,-8%) scale(0.9)} }

    /* ─── HERO MOUSE GLOW ─── */
    .hero-mouse-glow {
