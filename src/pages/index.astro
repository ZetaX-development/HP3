  <script>
    // INTRO staging: 縦罫 → 題字 → 幕明け。head の zx-hold ゲートと対で動く。
    const zxIntro = document.getElementById("zx-intro");
    if (zxIntro && document.documentElement.classList.contains("zx-hold")) {
      requestAnimationFrame(() => {
        zxIntro.classList.add("zxi-s1");                       // 縦罫が引かれる
        setTimeout(() => zxIntro.classList.add("zxi-s2"), 380); // 題字が刷り上がる
