    /* ─── HERO 2-COLUMN SPLIT ─── */
    .hero-content {
      max-width: 1140px; text-align: left; padding: 0 3rem;
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 3.5rem; align-items: center;
